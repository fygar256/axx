RCR BYTE [b+!o]B,CL    ::  ::  ;((b&8)?0x41:0),0xd2,0x58|(b&7),(o&0xff)
RCR BYTE [b+!o]B,!i    ::  ::  ;((b&8)?0x41:0),0xc0,0x58|(b&7),(o&0xff),(i&0xff)

/* SHL */
/* CLを!iより先に定義 (CLの番号=1がimm8にマッチするため) */
SHL d,CL               ::  ::  0x48|((d&8)>>3),0xd3,0xe0|(d&7)
SHL d,1                ::  ::  0x48|((d&8)>>3),0xd1,0xe0|(d&7)
SHL d,!i               ::  ::  0x48|((d&8)>>3),0xc1,0xe0|(d&7),(i&0xff)
SHL QWORD [b],CL       ::  ::  0x48|((b&8)>>3),0xd3,0x20|(b&7)
SHL QWORD [b],1        ::  ::  0x48|((b&8)>>3),0xd1,0x20|(b&7)
SHL QWORD [b],!i       ::  ::  0x48|((b&8)>>3),0xc1,0x20|(b&7),(i&0xff)
SHL QWORD [b+!o]B,CL   ::  ::  0x48|((b&8)>>3),0xd3,0x60|(b&7),(o&0xff)
SHL QWORD [b+!o]B,1    ::  ::  0x48|((b&8)>>3),0xd1,0x60|(b&7),(o&0xff)
SHL QWORD [b+!o]B,!i   ::  ::  0x48|((b&8)>>3),0xc1,0x60|(b&7),(o&0xff),(i&0xff)
SHL QWORD [b+!o],CL    ::  ::  0x48|((b&8)>>3),0xd3,0xa0|(b&7),@@[4,*(o,%%)]
SHL QWORD [b+!o],1     ::  ::  0x48|((b&8)>>3),0xd1,0xa0|(b&7),@@[4,*(o,%%)]
SHL QWORD [b+!o],!i    ::  ::  0x48|((b&8)>>3),0xc1,0xa0|(b&7),@@[4,*(o,%%)], (i&0xff)
SHL DWORD d,CL         ::  ::  ;((d&8)?0x41:0),0xd3,0xe0|(d&7)
SHL DWORD d,1          ::  ::  ;((d&8)?0x41:0),0xd1,0xe0|(d&7)
SHL DWORD d,!i         ::  ::  ;((d&8)?0x41:0),0xc1,0xe0|(d&7),(i&0xff)
SHL DWORD [b],CL       ::  ::  ;((b&8)?0x41:0),0xd3,0x20|(b&7)
SHL DWORD [b],1        ::  ::  ;((b&8)?0x41:0),0xd1,0x20|(b&7)
SHL DWORD [b],!i       ::  ::  ;((b&8)?0x41:0),0xc1,0x20|(b&7),(i&0xff)
SHL DWORD [b+!o]B,CL   ::  ::  ;((b&8)?0x41:0),0xd3,0x60|(b&7),(o&0xff)
SHL DWORD [b+!o]B,1    ::  ::  ;((b&8)?0x41:0),0xd1,0x60|(b&7),(o&0xff)
SHL DWORD [b+!o]B,!i   ::  ::  ;((b&8)?0x41:0),0xc1,0x60|(b&7),(o&0xff),(i&0xff)
SHL DWORD [b+!o],CL    ::  ::  ;((b&8)?0x41:0),0xd3,0xa0|(b&7),@@[4,*(o,%%)]
SHL DWORD [b+!o],1     ::  ::  ;((b&8)?0x41:0),0xd1,0xa0|(b&7),@@[4,*(o,%%)]
SHL DWORD [b+!o],!i    ::  ::  ;((b&8)?0x41:0),0xc1,0xa0|(b&7),@@[4,*(o,%%)], (i&0xff)
SHL WORD d,CL          ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xe0|(d&7)
SHL WORD d,1           ::  ::  0x66,;((d&8)?0x41:0),0xd1,0xe0|(d&7)
SHL WORD d,!i          ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xe0|(d&7),(i&0xff)
SHL WORD [b],CL        ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x20|(b&7)
SHL WORD [b],1         ::  ::  0x66,;((b&8)?0x41:0),0xd1,0x20|(b&7)
SHL WORD [b],!i        ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x20|(b&7),(i&0xff)
SHL WORD [b+!o]B,CL    ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x60|(b&7),(o&0xff)
SHL WORD [b+!o]B,!i    ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x60|(b&7),(o&0xff),(i&0xff)
SHL BYTE d,CL          ::  ::  ;((d&8)?0x41:0),0xd2,0xe0|(d&7)
SHL BYTE d,1           ::  ::  ;((d&8)?0x41:0),0xd0,0xe0|(d&7)
SHL BYTE d,!i          ::  ::  ;((d&8)?0x41:0),0xc0,0xe0|(d&7),(i&0xff)
SHL BYTE [b],CL        ::  ::  ;((b&8)?0x41:0),0xd2,0x20|(b&7)
SHL BYTE [b],1         ::  ::  ;((b&8)?0x41:0),0xd0,0x20|(b&7)
SHL BYTE [b],!i        ::  ::  ;((b&8)?0x41:0),0xc0,0x20|(b&7),(i&0xff)
SHL BYTE [b+!o]B,CL    ::  ::  ;((b&8)?0x41:0),0xd2,0x60|(b&7),(o&0xff)
SHL BYTE [b+!o]B,!i    ::  ::  ;((b&8)?0x41:0),0xc0,0x60|(b&7),(o&0xff),(i&0xff)

/* SHR */
/* CLを!iより先に定義 (CLの番号=1がimm8にマッチするため) */
SHR d,CL               ::  ::  0x48|((d&8)>>3),0xd3,0xe8|(d&7)
SHR d,1                ::  ::  0x48|((d&8)>>3),0xd1,0xe8|(d&7)
SHR d,!i               ::  ::  0x48|((d&8)>>3),0xc1,0xe8|(d&7),(i&0xff)
SHR QWORD [b],CL       ::  ::  0x48|((b&8)>>3),0xd3,0x28|(b&7)
SHR QWORD [b],1        ::  ::  0x48|((b&8)>>3),0xd1,0x28|(b&7)
SHR QWORD [b],!i       ::  ::  0x48|((b&8)>>3),0xc1,0x28|(b&7),(i&0xff)
SHR QWORD [b+!o]B,CL   ::  ::  0x48|((b&8)>>3),0xd3,0x68|(b&7),(o&0xff)
SHR QWORD [b+!o]B,1    ::  ::  0x48|((b&8)>>3),0xd1,0x68|(b&7),(o&0xff)
SHR QWORD [b+!o]B,!i   ::  ::  0x48|((b&8)>>3),0xc1,0x68|(b&7),(o&0xff),(i&0xff)
SHR QWORD [b+!o],CL    ::  ::  0x48|((b&8)>>3),0xd3,0xa8|(b&7),@@[4,*(o,%%)]
SHR QWORD [b+!o],1     ::  ::  0x48|((b&8)>>3),0xd1,0xa8|(b&7),@@[4,*(o,%%)]
SHR QWORD [b+!o],!i    ::  ::  0x48|((b&8)>>3),0xc1,0xa8|(b&7),@@[4,*(o,%%)], (i&0xff)
SHR DWORD d,CL         ::  ::  ;((d&8)?0x41:0),0xd3,0xe8|(d&7)
SHR DWORD d,1          ::  ::  ;((d&8)?0x41:0),0xd1,0xe8|(d&7)
SHR DWORD d,!i         ::  ::  ;((d&8)?0x41:0),0xc1,0xe8|(d&7),(i&0xff)
SHR DWORD [b],CL       ::  ::  ;((b&8)?0x41:0),0xd3,0x28|(b&7)
SHR DWORD [b],1        ::  ::  ;((b&8)?0x41:0),0xd1,0x28|(b&7)
SHR DWORD [b],!i       ::  ::  ;((b&8)?0x41:0),0xc1,0x28|(b&7),(i&0xff)
SHR DWORD [b+!o]B,CL   ::  ::  ;((b&8)?0x41:0),0xd3,0x68|(b&7),(o&0xff)
SHR DWORD [b+!o]B,1    ::  ::  ;((b&8)?0x41:0),0xd1,0x68|(b&7),(o&0xff)
SHR DWORD [b+!o]B,!i   ::  ::  ;((b&8)?0x41:0),0xc1,0x68|(b&7),(o&0xff),(i&0xff)
SHR DWORD [b+!o],CL    ::  ::  ;((b&8)?0x41:0),0xd3,0xa8|(b&7),@@[4,*(o,%%)]
SHR DWORD [b+!o],1     ::  ::  ;((b&8)?0x41:0),0xd1,0xa8|(b&7),@@[4,*(o,%%)]
SHR DWORD [b+!o],!i    ::  ::  ;((b&8)?0x41:0),0xc1,0xa8|(b&7),@@[4,*(o,%%)], (i&0xff)
SHR WORD d,CL          ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xe8|(d&7)
SHR WORD d,1           ::  ::  0x66,;((d&8)?0x41:0),0xd1,0xe8|(d&7)
SHR WORD d,!i          ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xe8|(d&7),(i&0xff)
SHR WORD [b],CL        ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x28|(b&7)
SHR WORD [b],1         ::  ::  0x66,;((b&8)?0x41:0),0xd1,0x28|(b&7)
SHR WORD [b],!i        ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x28|(b&7),(i&0xff)
SHR WORD [b+!o]B,CL    ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x68|(b&7),(o&0xff)
SHR WORD [b+!o]B,!i    ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x68|(b&7),(o&0xff),(i&0xff)
SHR BYTE d,CL          ::  ::  ;((d&8)?0x41:0),0xd2,0xe8|(d&7)
SHR BYTE d,1           ::  ::  ;((d&8)?0x41:0),0xd0,0xe8|(d&7)
SHR BYTE d,!i          ::  ::  ;((d&8)?0x41:0),0xc0,0xe8|(d&7),(i&0xff)
SHR BYTE [b],CL        ::  ::  ;((b&8)?0x41:0),0xd2,0x28|(b&7)
SHR BYTE [b],1         ::  ::  ;((b&8)?0x41:0),0xd0,0x28|(b&7)
SHR BYTE [b],!i        ::  ::  ;((b&8)?0x41:0),0xc0,0x28|(b&7),(i&0xff)
SHR BYTE [b+!o]B,CL    ::  ::  ;((b&8)?0x41:0),0xd2,0x68|(b&7),(o&0xff)
SHR BYTE [b+!o]B,!i    ::  ::  ;((b&8)?0x41:0),0xc0,0x68|(b&7),(o&0xff),(i&0xff)

/* SAR */
/* CLを!iより先に定義 (CLの番号=1がimm8にマッチするため) */
SAR d,CL               ::  ::  0x48|((d&8)>>3),0xd3,0xf8|(d&7)
SAR d,1                ::  ::  0x48|((d&8)>>3),0xd1,0xf8|(d&7)
SAR d,!i               ::  ::  0x48|((d&8)>>3),0xc1,0xf8|(d&7),(i&0xff)
SAR QWORD [b],CL       ::  ::  0x48|((b&8)>>3),0xd3,0x38|(b&7)
SAR QWORD [b],1        ::  ::  0x48|((b&8)>>3),0xd1,0x38|(b&7)
SAR QWORD [b],!i       ::  ::  0x48|((b&8)>>3),0xc1,0x38|(b&7),(i&0xff)
SAR QWORD [b+!o]B,CL   ::  ::  0x48|((b&8)>>3),0xd3,0x78|(b&7),(o&0xff)
SAR QWORD [b+!o]B,1    ::  ::  0x48|((b&8)>>3),0xd1,0x78|(b&7),(o&0xff)
SAR QWORD [b+!o]B,!i   ::  ::  0x48|((b&8)>>3),0xc1,0x78|(b&7),(o&0xff),(i&0xff)
SAR QWORD [b+!o],CL    ::  ::  0x48|((b&8)>>3),0xd3,0xb8|(b&7),@@[4,*(o,%%)]
SAR QWORD [b+!o],1     ::  ::  0x48|((b&8)>>3),0xd1,0xb8|(b&7),@@[4,*(o,%%)]
SAR QWORD [b+!o],!i    ::  ::  0x48|((b&8)>>3),0xc1,0xb8|(b&7),@@[4,*(o,%%)], (i&0xff)
SAR DWORD d,CL         ::  ::  ;((d&8)?0x41:0),0xd3,0xf8|(d&7)
SAR DWORD d,1          ::  ::  ;((d&8)?0x41:0),0xd1,0xf8|(d&7)
SAR DWORD d,!i         ::  ::  ;((d&8)?0x41:0),0xc1,0xf8|(d&7),(i&0xff)
SAR DWORD [b],CL       ::  ::  ;((b&8)?0x41:0),0xd3,0x38|(b&7)
SAR DWORD [b],1        ::  ::  ;((b&8)?0x41:0),0xd1,0x38|(b&7)
SAR DWORD [b],!i       ::  ::  ;((b&8)?0x41:0),0xc1,0x38|(b&7),(i&0xff)
SAR DWORD [b+!o]B,CL   ::  ::  ;((b&8)?0x41:0),0xd3,0x78|(b&7),(o&0xff)
SAR DWORD [b+!o]B,1    ::  ::  ;((b&8)?0x41:0),0xd1,0x78|(b&7),(o&0xff)
SAR DWORD [b+!o]B,!i   ::  ::  ;((b&8)?0x41:0),0xc1,0x78|(b&7),(o&0xff),(i&0xff)
SAR DWORD [b+!o],CL    ::  ::  ;((b&8)?0x41:0),0xd3,0xb8|(b&7),@@[4,*(o,%%)]
SAR DWORD [b+!o],1     ::  ::  ;((b&8)?0x41:0),0xd1,0xb8|(b&7),@@[4,*(o,%%)]
SAR DWORD [b+!o],!i    ::  ::  ;((b&8)?0x41:0),0xc1,0xb8|(b&7),@@[4,*(o,%%)], (i&0xff)
SAR WORD d,CL          ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xf8|(d&7)
SAR WORD d,1           ::  ::  0x66,;((d&8)?0x41:0),0xd1,0xf8|(d&7)
SAR WORD d,!i          ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xf8|(d&7),(i&0xff)
SAR WORD [b],CL        ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x38|(b&7)
SAR WORD [b],1         ::  ::  0x66,;((b&8)?0x41:0),0xd1,0x38|(b&7)
SAR WORD [b],!i        ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x38|(b&7),(i&0xff)
SAR WORD [b+!o]B,CL    ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x78|(b&7),(o&0xff)
SAR WORD [b+!o]B,!i    ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x78|(b&7),(o&0xff),(i&0xff)
SAR BYTE d,CL          ::  ::  ;((d&8)?0x41:0),0xd2,0xf8|(d&7)
SAR BYTE d,1           ::  ::  ;((d&8)?0x41:0),0xd0,0xf8|(d&7)
SAR BYTE d,!i          ::  ::  ;((d&8)?0x41:0),0xc0,0xf8|(d&7),(i&0xff)
SAR BYTE [b],CL        ::  ::  ;((b&8)?0x41:0),0xd2,0x38|(b&7)
SAR BYTE [b],1         ::  ::  ;((b&8)?0x41:0),0xd0,0x38|(b&7)
SAR BYTE [b],!i        ::  ::  ;((b&8)?0x41:0),0xc0,0x38|(b&7),(i&0xff)
SAR BYTE [b+!o]B,CL    ::  ::  ;((b&8)?0x41:0),0xd2,0x78|(b&7),(o&0xff)
SAR BYTE [b+!o]B,!i    ::  ::  ;((b&8)?0x41:0),0xc0,0x78|(b&7),(o&0xff),(i&0xff)

/* SHLD / SHRD (全モード) */
SHLD d,s,CL             ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa5,0xc0|((s&7)<<3)|(d&7)
SHLD d,s,!i             ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa4,0xc0|((s&7)<<3)|(d&7),(i&0xff)
SHLD [b],s,CL           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa5,((s&7)<<3)|(b&7)
SHLD [b],s,!i           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa4,((s&7)<<3)|(b&7),(i&0xff)
SHLD [b+!o]B,s,CL       ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa5,0x40|((s&7)<<3)|(b&7),(o&0xff)
SHLD [b+!o]B,s,!i       ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa4,0x40|((s&7)<<3)|(b&7),(o&0xff),(i&0xff)
SHLD [b+!o],s,CL        ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa5,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
SHLD [b+!o],s,!i        ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa4,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)], (i&0xff)
SHLD DWORD d,s,CL       ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xa5,0xc0|((s&7)<<3)|(d&7)
SHLD DWORD d,s,!i       ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xa4,0xc0|((s&7)<<3)|(d&7),(i&0xff)

SHRD d,s,CL             ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xad,0xc0|((s&7)<<3)|(d&7)
SHRD d,s,!i             ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xac,0xc0|((s&7)<<3)|(d&7),(i&0xff)
SHRD [b],s,CL           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xad,((s&7)<<3)|(b&7)
SHRD [b],s,!i           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xac,((s&7)<<3)|(b&7),(i&0xff)
SHRD [b+!o]B,s,CL       ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xad,0x40|((s&7)<<3)|(b&7),(o&0xff)
SHRD [b+!o]B,s,!i       ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xac,0x40|((s&7)<<3)|(b&7),(o&0xff),(i&0xff)
SHRD [b+!o],s,CL        ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xad,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
SHRD [b+!o],s,!i        ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xac,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)], (i&0xff)
SHRD DWORD d,s,CL       ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xad,0xc0|((s&7)<<3)|(d&7)
SHRD DWORD d,s,!i       ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xac,0xc0|((s&7)<<3)|(d&7),(i&0xff)

/* ====================== ビット操作 BT/BTS/BTR/BTC (全アドレッシングモード) ====================== */
/* BT */
BT d,s                 ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa3,0xc0|((s&7)<<3)|(d&7)
BT d,!i                ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xe0|(d&7),(i&0xff)
BT [b],s               ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa3,((s&7)<<3)|(b&7)
BT [b+!o]B,s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa3,0x40|((s&7)<<3)|(b&7),(o&0xff)
BT [b+!o],s            ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xa3,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
BT QWORD [b],!i        ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x20|(b&7),(i&0xff)
BT QWORD [b+!o]B,!i    ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x60|(b&7),(o&0xff),(i&0xff)
BT DWORD d,s           ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xa3,0xc0|((s&7)<<3)|(d&7)
BT DWORD [b],s         ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xa3,((s&7)<<3)|(b&7)
BT DWORD [b+!o]B,s     ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xa3,0x40|((s&7)<<3)|(b&7),(o&0xff)

/* BTS */
BTS d,s                 ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xab,0xc0|((s&7)<<3)|(d&7)
BTS d,!i                ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xe8|(d&7),(i&0xff)
BTS [b],s               ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xab,((s&7)<<3)|(b&7)
BTS [b+!o]B,s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xab,0x40|((s&7)<<3)|(b&7),(o&0xff)
BTS [b+!o],s            ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xab,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
BTS QWORD [b],!i        ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x28|(b&7),(i&0xff)
BTS QWORD [b+!o]B,!i    ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x68|(b&7),(o&0xff),(i&0xff)
BTS DWORD d,s           ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xab,0xc0|((s&7)<<3)|(d&7)
BTS DWORD [b],s         ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xab,((s&7)<<3)|(b&7)
BTS DWORD [b+!o]B,s     ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xab,0x40|((s&7)<<3)|(b&7),(o&0xff)

/* BTR */
BTR d,s                 ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xb3,0xc0|((s&7)<<3)|(d&7)
BTR d,!i                ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xf0|(d&7),(i&0xff)
BTR [b],s               ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb3,((s&7)<<3)|(b&7)
BTR [b+!o]B,s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb3,0x40|((s&7)<<3)|(b&7),(o&0xff)
BTR [b+!o],s            ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb3,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
BTR QWORD [b],!i        ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x30|(b&7),(i&0xff)
BTR QWORD [b+!o]B,!i    ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x70|(b&7),(o&0xff),(i&0xff)
BTR DWORD d,s           ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xb3,0xc0|((s&7)<<3)|(d&7)
BTR DWORD [b],s         ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xb3,((s&7)<<3)|(b&7)
BTR DWORD [b+!o]B,s     ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xb3,0x40|((s&7)<<3)|(b&7),(o&0xff)

/* BTC */
BTC d,s                 ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xbb,0xc0|((s&7)<<3)|(d&7)
BTC d,!i                ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xf8|(d&7),(i&0xff)
BTC [b],s               ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xbb,((s&7)<<3)|(b&7)
BTC [b+!o]B,s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xbb,0x40|((s&7)<<3)|(b&7),(o&0xff)
BTC [b+!o],s            ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xbb,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
BTC QWORD [b],!i        ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x38|(b&7),(i&0xff)
BTC QWORD [b+!o]B,!i    ::  ::  0x48|((b&8)>>3),0x0f,0xba,0x78|(b&7),(o&0xff),(i&0xff)
BTC DWORD d,s           ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x0f,0xbb,0xc0|((s&7)<<3)|(d&7)
BTC DWORD [b],s         ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xbb,((s&7)<<3)|(b&7)
BTC DWORD [b+!o]B,s     ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xbb,0x40|((s&7)<<3)|(b&7),(o&0xff)

/* [修正済] BT/BTS/BTR/BTC のimm版メモリ形式は上で直接修正済 */
/* BSF / BSR / POPCNT / LZCNT / TZCNT */
BSF d,s                 ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
BSF d,[b]               ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbc,((d&7)<<3)|(b&7)
BSF d,[b+!o]B           ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbc,0x40|((d&7)<<3)|(b&7),(o&0xff)
BSF d,[b+!o]            ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbc,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
BSF DWORD d,s           ::  ::  ;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
BSF DWORD d,[b]         ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbc,((d&7)<<3)|(b&7)
BSF DWORD d,[b+!o]B     ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbc,0x40|((d&7)<<3)|(b&7),(o&0xff)

BSR d,s                 ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)
BSR d,[b]               ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbd,((d&7)<<3)|(b&7)
BSR d,[b+!o]B           ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbd,0x40|((d&7)<<3)|(b&7),(o&0xff)
BSR d,[b+!o]            ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbd,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
BSR DWORD d,s           ::  ::  ;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)
BSR DWORD d,[b]         ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbd,((d&7)<<3)|(b&7)
BSR DWORD d,[b+!o]B     ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbd,0x40|((d&7)<<3)|(b&7),(o&0xff)

POPCNT d,s                 ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xb8,0xc0|((d&7)<<3)|(s&7)
POPCNT d,[b]               ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb8,((d&7)<<3)|(b&7)
POPCNT d,[b+!o]B           ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb8,0x40|((d&7)<<3)|(b&7),(o&0xff)
POPCNT d,[b+!o]            ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb8,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
POPCNT DWORD d,s           ::  ::  0xf3,;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xb8,0xc0|((d&7)<<3)|(s&7)
POPCNT DWORD d,[b]         ::  ::  0xf3,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xb8,((d&7)<<3)|(b&7)
POPCNT DWORD d,[b+!o]B     ::  ::  0xf3,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xb8,0x40|((d&7)<<3)|(b&7),(o&0xff)

LZCNT d,s                 ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)
LZCNT d,[b]               ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbd,((d&7)<<3)|(b&7)
LZCNT d,[b+!o]B           ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbd,0x40|((d&7)<<3)|(b&7),(o&0xff)
LZCNT d,[b+!o]            ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbd,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
LZCNT DWORD d,s           ::  ::  0xf3,;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)
LZCNT DWORD d,[b]         ::  ::  0xf3,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbd,((d&7)<<3)|(b&7)
LZCNT DWORD d,[b+!o]B     ::  ::  0xf3,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbd,0x40|((d&7)<<3)|(b&7),(o&0xff)

TZCNT d,s                 ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
TZCNT d,[b]               ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbc,((d&7)<<3)|(b&7)
TZCNT d,[b+!o]B           ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbc,0x40|((d&7)<<3)|(b&7),(o&0xff)
TZCNT d,[b+!o]            ::  ::  0xf3,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xbc,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
TZCNT DWORD d,s           ::  ::  0xf3,;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
TZCNT DWORD d,[b]         ::  ::  0xf3,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbc,((d&7)<<3)|(b&7)
TZCNT DWORD d,[b+!o]B     ::  ::  0xf3,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0xbc,0x40|((d&7)<<3)|(b&7),(o&0xff)

/* BSWAP */
BSWAP d                 ::  ::  0x48|((d&8)>>3),0x0f,0xc8|(d&7)
BSWAP DWORD d           ::  ::  ;((d&8)?0x41:0),0x0f,0xc8|(d&7)

/* ====================== XCHG / CMPXCHG / XADD (全アドレッシングモード) ====================== */
XCHG RAX,d              ::  ::  0x48|((d&8)>>3),0x90|(d&7)
XCHG d,RAX              ::  ::  0x48|((d&8)>>3),0x90|(d&7)
XCHG d,s                ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x87,0xc0|(d&7)|((s&7)<<3)
XCHG [b],s              ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x87,((s&7)<<3)|(b&7)
XCHG [b+!o]B,s          ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x87,0x40|((s&7)<<3)|(b&7),(o&0xff)
XCHG [b+!o],s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x87,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
XCHG DWORD d,s          ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x87,0xc0|(d&7)|((s&7)<<3)
XCHG DWORD [b],s        ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x87,((s&7)<<3)|(b&7)
CMPXCHG d,s             ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xb1,0xc0|(d&7)|((s&7)<<3)
CMPXCHG [b],s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb1,((s&7)<<3)|(b&7)
CMPXCHG [b+!o]B,s       ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb1,0x40|((s&7)<<3)|(b&7),(o&0xff)
CMPXCHG [b+!o],s        ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb1,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
CMPXCHG8B [b]           ::  ::  ;((b&8)?0x41:0),0x0f,0xc7,0x08|(b&7)
CMPXCHG16B [b]          ::  ::  0x48|((b&8)>>3),0x0f,0xc7,0x08|(b&7)
XADD d,s                ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xc1,0xc0|(d&7)|((s&7)<<3)
XADD [b],s              ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xc1,((s&7)<<3)|(b&7)
XADD [b+!o]B,s          ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xc1,0x40|((s&7)<<3)|(b&7),(o&0xff)
XADD [b+!o],s           ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xc1,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
XADD DWORD [b],s        ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xc1,((s&7)<<3)|(b&7)
XADD BYTE [b],s         ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xc0,((s&7)<<3)|(b&7)

/* ====================== LOCK プレフィックス (全アドレッシングモード) ====================== */
LOCK_ADD [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x01,((s&7)<<3)|(b&7)
LOCK_ADD [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x01,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_ADD [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x01,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_ADD DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x01,((s&7)<<3)|(b&7)
LOCK_ADD BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x00,((s&7)<<3)|(b&7)
LOCK_SUB [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x29,((s&7)<<3)|(b&7)
LOCK_SUB [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x29,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_SUB [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x29,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_SUB DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x29,((s&7)<<3)|(b&7)
LOCK_SUB BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x28,((s&7)<<3)|(b&7)
LOCK_AND [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x21,((s&7)<<3)|(b&7)
LOCK_AND [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x21,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_AND [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x21,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_AND DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x21,((s&7)<<3)|(b&7)
LOCK_AND BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x20,((s&7)<<3)|(b&7)
LOCK_OR [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x09,((s&7)<<3)|(b&7)
LOCK_OR [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x09,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_OR [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x09,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_OR DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x09,((s&7)<<3)|(b&7)
LOCK_OR BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x08,((s&7)<<3)|(b&7)
LOCK_XOR [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x31,((s&7)<<3)|(b&7)
LOCK_XOR [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x31,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_XOR [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x31,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_XOR DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x31,((s&7)<<3)|(b&7)
LOCK_XOR BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x30,((s&7)<<3)|(b&7)
LOCK_ADC [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x11,((s&7)<<3)|(b&7)
LOCK_ADC [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x11,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_ADC [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x11,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_ADC DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x11,((s&7)<<3)|(b&7)
LOCK_ADC BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x10,((s&7)<<3)|(b&7)
LOCK_SBB [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x19,((s&7)<<3)|(b&7)
LOCK_SBB [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x19,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_SBB [b+!o],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x19,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
LOCK_SBB DWORD [b],s   ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x19,((s&7)<<3)|(b&7)
LOCK_SBB BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x18,((s&7)<<3)|(b&7)
/* LOCK INC/DEC */
LOCK_INC QWORD [b]      ::  ::  0xf0,0x48|((b&8)>>3),0xff,0x00|(b&7)
LOCK_INC QWORD [b+!o]B  ::  ::  0xf0,0x48|((b&8)>>3),0xff,0x40|(b&7),(o&0xff)
LOCK_DEC QWORD [b]      ::  ::  0xf0,0x48|((b&8)>>3),0xff,0x08|(b&7)
LOCK_DEC QWORD [b+!o]B  ::  ::  0xf0,0x48|((b&8)>>3),0xff,0x48|(b&7),(o&0xff)
LOCK_INC BYTE [b]       ::  ::  0xf0,;((b&8)?0x41:0),0xfe,0x00|(b&7)
LOCK_DEC BYTE [b]       ::  ::  0xf0,;((b&8)?0x41:0),0xfe,0x08|(b&7)
/* LOCK CMPXCHG/XADD */
LOCK_CMPXCHG [b],s      ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb1,((s&7)<<3)|(b&7)
LOCK_CMPXCHG [b+!o]B,s  ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb1,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_XADD [b],s         ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xc1,((s&7)<<3)|(b&7)
LOCK_XADD [b+!o]B,s     ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xc1,0x40|((s&7)<<3)|(b&7),(o&0xff)
LOCK_XADD BYTE [b],s    ::  ::  0xf0,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0xc0,((s&7)<<3)|(b&7)
LOCK_BTS QWORD [b],s   ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xab,((s&7)<<3)|(b&7)
LOCK_BTR QWORD [b],s   ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb3,((s&7)<<3)|(b&7)
LOCK_BTC QWORD [b],s   ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xbb,((s&7)<<3)|(b&7)


/* ====================== AVX (VEX 3バイト形式) ====================== */
/*
   C4 [byte2] [byte3] opcode ModRM [imm]
   byte2 = (~x>>3&1)<<5 | 0x61 | (~z>>3&1)   (map=0Fh)
   byte3 = (~y&0xf)<<3  | (L<<2) | pp
     x=dest, y=vvvv(src1), z=src2/r/m
     L=0:128bit  L=1:256bit
     pp: 0=none 1=0x66 2=0xf3 3=0xf2
*/
/* VMOV */
VMOVSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x10,0xc0|((x&7)<<3)|(z&7)
VMOVSD x,[b]  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(b)>>3&1))&0xff,((~(0xf)&0xf)<<3|2)&0xff,0x10,((x&7)<<3)|(b&7)
VMOVSS x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|3)&0xff,0x10,0xc0|((x&7)<<3)|(z&7)
VMOVSS x,[b]  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(b)>>3&1))&0xff,((~(0xf)&0xf)<<3|3)&0xff,0x10,((x&7)<<3)|(b&7)
VMOVAPS x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|0)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVAPS256 x,y ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|(1<<2)|0)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVAPD x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|1)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVAPD256 x,y ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|(1<<2)|1)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVUPS x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|0)&0xff,0x10,0xc0|((x&7)<<3)|(y&7)

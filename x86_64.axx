/* ========================================
   x86_64 完全パターンファイル for axx  v6.0
   全アドレッシングモード対応版

   追加 (v6.0):
     SSE3: ADDSUBPD/PS, HADDPD/PS, HSUBPD/PS, MOVDDUP,
           MOVSLDUP, MOVSHDUP, LDDQU, MONITOR, MWAIT
     SSE4.2: CRC32 (64/32/8bit src)
     RDRAND / RDSEED (64/32/16bit)
     MOVBE (load/store, 64/32bit)
     SIB scale=1: [b+r*1] 全パターン
     ALU store方向: ADD/SUB/AND/OR/XOR [b+r*scale],s

   アドレッシングモード一覧:
     d,s          : レジスタ直接
     d,!i         : 即値 (imm32)
     d8 d,!i      : 即値 (imm8 符号拡張)
     d,[b]        : レジスタ間接
     d,[b+!o]B    : ベース+disp8
     d,[b+!o]     : ベース+disp32
     d,[RIP+!a]   : RIP相対
     [b],s        : メモリ→レジスタ(store)
     [b+!o]B,s    : disp8 store
     [b+!o],s     : disp32 store
     SIZE [b],!i  : メモリに即値

   SIZE修飾子: QWORD/DWORD/WORD/BYTE
   注: RSP(4)/R12(12)ベースはSIB必要(別途)
   ======================================== */

/* ====================== レジスタ定義 ====================== */
.setsym::RAX::0
.setsym::RCX::1
.setsym::RDX::2
.setsym::RBX::3
.setsym::RSP::4
.setsym::RBP::5
.setsym::RSI::6
.setsym::RDI::7
.setsym::R8::8
.setsym::R9::9
.setsym::R10::10
.setsym::R11::11
.setsym::R12::12
.setsym::R13::13
.setsym::R14::14
.setsym::R15::15

.setsym::EAX::0
.setsym::ECX::1
.setsym::EDX::2
.setsym::EBX::3
.setsym::ESP::4
.setsym::EBP::5
.setsym::ESI::6
.setsym::EDI::7
.setsym::R8D::8
.setsym::R9D::9
.setsym::R10D::10
.setsym::R11D::11
.setsym::R12D::12
.setsym::R13D::13
.setsym::R14D::14
.setsym::R15D::15

.setsym::AX::0
.setsym::CX::1
.setsym::DX::2
.setsym::BX::3
.setsym::SP::4
.setsym::BP::5
.setsym::SI::6
.setsym::DI::7
.setsym::R8W::8
.setsym::R9W::9
.setsym::R10W::10
.setsym::R11W::11
.setsym::R12W::12
.setsym::R13W::13
.setsym::R14W::14
.setsym::R15W::15

.setsym::AL::0
.setsym::CL::1
.setsym::DL::2
.setsym::BL::3
.setsym::SPL::4
.setsym::BPL::5
.setsym::SIL::6
.setsym::DIL::7
.setsym::R8B::8
.setsym::R9B::9
.setsym::R10B::10
.setsym::R11B::11
.setsym::R12B::12
.setsym::R13B::13
.setsym::R14B::14
.setsym::R15B::15
.setsym::AH::4
.setsym::CH::5
.setsym::DH::6
.setsym::BH::7

.setsym::XMM0::0
.setsym::XMM1::1
.setsym::XMM2::2
.setsym::XMM3::3
.setsym::XMM4::4
.setsym::XMM5::5
.setsym::XMM6::6
.setsym::XMM7::7
.setsym::XMM8::8
.setsym::XMM9::9
.setsym::XMM10::10
.setsym::XMM11::11
.setsym::XMM12::12
.setsym::XMM13::13
.setsym::XMM14::14
.setsym::XMM15::15

.setsym::YMM0::0
.setsym::YMM1::1
.setsym::YMM2::2
.setsym::YMM3::3
.setsym::YMM4::4
.setsym::YMM5::5
.setsym::YMM6::6
.setsym::YMM7::7
.setsym::YMM8::8
.setsym::YMM9::9
.setsym::YMM10::10
.setsym::YMM11::11
.setsym::YMM12::12
.setsym::YMM13::13
.setsym::YMM14::14
.setsym::YMM15::15

.setsym::ES::0
.setsym::CS::1
.setsym::SS::2
.setsym::DS::3
.setsym::FS::4
.setsym::GS::5

/* ====================== データ定義 ====================== */
DB !e  ::  ::  e
DW !e  ::  ::  @@[2,*(e,%%)]
DD !e  ::  ::  @@[4,*(e,%%)]
DQ !e  ::  ::  @@[8,*(e,%%)]

/* ====================== [symbol+reg] SIBアドレッシング ====================== */
/*
   disp32 + index*1 (base なし) アドレッシング。
   s を「symbol: .equ addr::abs32」で定義すると、
   4バイトフィールドに R_X86_64_32 リロケーションが生成される。

   符号化:
     REX  : ;((r&8)?0x42:0)  ← REX.X bit のみ (index が r8-r15 のとき)
     opcode: 0xFE / 0x80 など
     ModRM : mod=00, /op, r/m=4(SIB)
     SIB   : scale=00, index=(r&7), base=101(disp32のみ) → ((r&7)<<3)|5
     disp32: @@[4,*(s,%%)]
*/
INC BYTE  [!s\+r]      ::  ::  ;((r&8)?0x42:0),0xfe,0x04,((r&7)<<3)|5,@@[4,*(s,%%)]
DEC BYTE  [!s\+r]      ::  ::  ;((r&8)?0x42:0),0xfe,0x0c,((r&7)<<3)|5,@@[4,*(s,%%)]
CMP BYTE  [!s\+r],!i   ::  ::  ;((r&8)?0x42:0),0x80,0x3c,((r&7)<<3)|5,@@[4,*(s,%%)],(i&0xff)
MOV BYTE  d,[!s\+r]    ::  ::  ;((r&8)?0x42:0),0x8a,0x04|((d&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]
MOV BYTE  [!s\+r],d    ::  ::  ;((r&8)?0x42:0),0x88,0x04|((d&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]


/* ====================== RSP/R12 ベース: SIB=0x24 必要 ====================== */
/* RSP(4)/R12(12) が rm=100 のとき CPU は SIB バイトを期待する。
   SIB=0x24: scale=00, index=100(none), base=100(RSP/R12)
   R12: REX.B=1 で base=100 → R12 を指す。                            */
/* 64bit load */
MOV d,[RSP]             ::  ::  0x48|((d&8)>>1),0x8b,((d&7)<<3)|0x04,0x24
MOV d,[RSP+!o]B         ::  ::  0x48|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
MOV d,[RSP+!o]          ::  ::  0x48|((d&8)>>1),0x8b,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV d,[R12]             ::  ::  0x49|((d&8)>>1),0x8b,((d&7)<<3)|0x04,0x24
MOV d,[R12+!o]B         ::  ::  0x49|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
MOV d,[R12+!o]          ::  ::  0x49|((d&8)>>1),0x8b,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
/* 64bit store */
MOV [RSP],s             ::  ::  0x48|((s&8)>>1),0x89,((s&7)<<3)|0x04,0x24
MOV [RSP+!o]B,s         ::  ::  0x48|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x04,0x24,(o&0xff)
MOV [RSP+!o],s          ::  ::  0x48|((s&8)>>1),0x89,0x80|((s&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV [R12],s             ::  ::  0x49|((s&8)>>1),0x89,((s&7)<<3)|0x04,0x24
MOV [R12+!o]B,s         ::  ::  0x49|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x04,0x24,(o&0xff)
MOV [R12+!o],s          ::  ::  0x49|((s&8)>>1),0x89,0x80|((s&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
/* 64bit immediate */
MOV QWORD [RSP],!i      ::  ::  0x48,0xc7,0x04,0x24,@@[4,*(i,%%)]
MOV QWORD [RSP+!o]B,!i  ::  ::  0x48,0xc7,0x44,0x24,(o&0xff),@@[4,*(i,%%)]
MOV QWORD [RSP+!o],!i   ::  ::  0x48,0xc7,0x84,0x24,@@[4,*(o,%%)],@@[4,*(i,%%)]
MOV QWORD [R12],!i      ::  ::  0x49,0xc7,0x04,0x24,@@[4,*(i,%%)]
MOV QWORD [R12+!o]B,!i  ::  ::  0x49,0xc7,0x44,0x24,(o&0xff),@@[4,*(i,%%)]
MOV QWORD [R12+!o],!i   ::  ::  0x49,0xc7,0x84,0x24,@@[4,*(o,%%)],@@[4,*(i,%%)]

/* ====================== RBP/R13 ベース: mod=00 は RIP相対になるので mod=01,disp8=0 を使う ====================== */
/* mod=00, rm=101 → disp32(RIP相対)。RBP/R13 間接参照は mod=01, disp8=0x00 が正しい。 */
MOV d,[RBP]             ::  ::  0x48|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x05,0x00
MOV d,[R13]             ::  ::  0x49|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x05,0x00
MOV [RBP],s             ::  ::  0x48|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x05,0x00
MOV [R13],s             ::  ::  0x49|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x05,0x00
MOV QWORD [RBP],!i      ::  ::  0x48,0xc7,0x45,0x00,@@[4,*(i,%%)]
MOV QWORD [R13],!i      ::  ::  0x49,0xc7,0x45,0x00,@@[4,*(i,%%)]

/* ====================== SIBスケールドアドレッシング [base+index*scale] ====================== */
/* scale=2(01)/4(10)/8(11), SIB = (ss<<6)|((r&7)<<3)|(b&7)
   mod=00: disp なし, mod=01: disp8, mod=10: disp32
   REX: W=1固定, R=d>>3, X=r>>3(index), B=b>>3(base)                  */


/* --- [b+r*1] scale=1, SIB.ss=00 --- */
MOV d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
MOV d,[b+r*1+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x44|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),(o&0xff)
MOV d,[b+r*1+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
MOV [b+r*1],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x04|((s&7)<<3),(0x00|((r&7)<<3)|(b&7))
MOV [b+r*1+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x44|((s&7)<<3),(0x00|((r&7)<<3)|(b&7)),(o&0xff)
MOV [b+r*1+!o],s        ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x84|((s&7)<<3),(0x00|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
LEA d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8d,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
LEA d,[b+r*1+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8d,0x44|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),(o&0xff)
LEA d,[b+r*1+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8d,0x84|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
ADD d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x03,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
ADD d,[b+r*1+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x03,0x44|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),(o&0xff)
SUB d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x2b,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
SUB d,[b+r*1+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x2b,0x44|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),(o&0xff)
CMP d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x3b,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
CMP d,[b+r*1+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x3b,0x44|((d&7)<<3),(0x00|((r&7)<<3)|(b&7)),(o&0xff)
AND d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x23,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
OR  d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x0b,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))
XOR d,[b+r*1]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x33,0x04|((d&7)<<3),(0x00|((r&7)<<3)|(b&7))

/* --- ALU store [b+r*scale] (store方向: 64bit) --- */
ADD [b+r*2],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x01,0x04|((s&7)<<3),(0x40|((r&7)<<3)|(b&7))
ADD [b+r*4],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x01,0x04|((s&7)<<3),(0x80|((r&7)<<3)|(b&7))
ADD [b+r*8],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x01,0x04|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7))
ADD [b+r*2+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x01,0x44|((s&7)<<3),(0x40|((r&7)<<3)|(b&7)),(o&0xff)
ADD [b+r*4+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x01,0x44|((s&7)<<3),(0x80|((r&7)<<3)|(b&7)),(o&0xff)
ADD [b+r*8+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x01,0x44|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7)),(o&0xff)
SUB [b+r*2],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x29,0x04|((s&7)<<3),(0x40|((r&7)<<3)|(b&7))
SUB [b+r*4],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x29,0x04|((s&7)<<3),(0x80|((r&7)<<3)|(b&7))
SUB [b+r*8],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x29,0x04|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7))
AND [b+r*2],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x21,0x04|((s&7)<<3),(0x40|((r&7)<<3)|(b&7))
AND [b+r*4],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x21,0x04|((s&7)<<3),(0x80|((r&7)<<3)|(b&7))
AND [b+r*8],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x21,0x04|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7))
OR  [b+r*2],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x09,0x04|((s&7)<<3),(0x40|((r&7)<<3)|(b&7))
OR  [b+r*4],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x09,0x04|((s&7)<<3),(0x80|((r&7)<<3)|(b&7))
OR  [b+r*8],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x09,0x04|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7))
XOR [b+r*2],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x31,0x04|((s&7)<<3),(0x40|((r&7)<<3)|(b&7))
XOR [b+r*4],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x31,0x04|((s&7)<<3),(0x80|((r&7)<<3)|(b&7))
XOR [b+r*8],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x31,0x04|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7))
/* --- MOV 64bit load [b+r*scale] --- */
MOV d,[b+r*2]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x04|((d&7)<<3),(0x40|((r&7)<<3)|(b&7))
MOV d,[b+r*4]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x04|((d&7)<<3),(0x80|((r&7)<<3)|(b&7))
MOV d,[b+r*8]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x04|((d&7)<<3),(0xc0|((r&7)<<3)|(b&7))
MOV d,[b+r*2+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x44|((d&7)<<3),(0x40|((r&7)<<3)|(b&7)),(o&0xff)
MOV d,[b+r*4+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x44|((d&7)<<3),(0x80|((r&7)<<3)|(b&7)),(o&0xff)
MOV d,[b+r*8+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x44|((d&7)<<3),(0xc0|((r&7)<<3)|(b&7)),(o&0xff)
MOV d,[b+r*2+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3),(0x40|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
MOV d,[b+r*4+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3),(0x80|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
MOV d,[b+r*8+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3),(0xc0|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]

/* --- MOV 64bit store [b+r*scale] --- */
MOV [b+r*2],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x04|((s&7)<<3),(0x40|((r&7)<<3)|(b&7))
MOV [b+r*4],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x04|((s&7)<<3),(0x80|((r&7)<<3)|(b&7))
MOV [b+r*8],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x04|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7))
MOV [b+r*2+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x44|((s&7)<<3),(0x40|((r&7)<<3)|(b&7)),(o&0xff)
MOV [b+r*4+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x44|((s&7)<<3),(0x80|((r&7)<<3)|(b&7)),(o&0xff)
MOV [b+r*8+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x44|((s&7)<<3),(0xc0|((r&7)<<3)|(b&7)),(o&0xff)
MOV [b+r*2+!o],s        ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x84|((s&7)<<3),(0x40|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]

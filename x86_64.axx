VMOVDQA x,y    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|1)&0xff,0x6f,0xc0|((x&7)<<3)|(y&7)
VMOVDQU x,y    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((~(0xf)&0xf)<<3|2)&0xff,0x6f,0xc0|((x&7)<<3)|(y&7)

CMOVL  d,[b] ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x4c,((d&7)<<3)|(b&7)
CMOVGE d,[b] ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x4d,((d&7)<<3)|(b&7)
CMOVLE d,[b] ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x4e,((d&7)<<3)|(b&7)
CMOVG  d,[b] ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x4f,((d&7)<<3)|(b&7)

/* ====================== PUSH/POP ====================== */

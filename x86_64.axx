/* ====================== SSE4.2 追加命令 ====================== */
/* CRC32: F2 REX 0F38 F0(←r/m8) / F1(←r/m16/32/64) */
CRC32 d,s                ::  ::  0xf2,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0x38,0xf1,0xc0|((d&7)<<3)|(s&7)

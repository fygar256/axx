/* ====================== AES-NI ====================== */
AESENC x,y  ::  ::  0x66,;(((x|y)&8)?(0x40|((x&8)>>1)|((y&8)>>3)):0),0x0f,0x38,0xdc,0xc0|((x&7)<<3)|(y&7)

/* ====================== PUSHF/POPF ====================== */

/* ====================== SETcc バイトレジスタ直接指定 (REX省略版) ====================== */
/* 'd' はレジスタ番号を受け取るが al/cl/dl/bl=0-3 は REX不要 */
SETO  BYTE [b]          ::  ::  ;((b&8)?0x41:0),0x0f,0x90,0x00|(b&7)
SETO  BYTE [b+!o]B      ::  ::  ;((b&8)?0x41:0),0x0f,0x90,0x40|(b&7),(o&0xff)
SETNO BYTE [b]          ::  ::  ;((b&8)?0x41:0),0x0f,0x91,0x00|(b&7)
SETNO BYTE [b+!o]B      ::  ::  ;((b&8)?0x41:0),0x0f,0x91,0x40|(b&7),(o&0xff)

/* ====================== CRC32 ====================== */
CRC32 d,s               ::  ::  0xf2,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0x38,0xf1,0xc0|((d&7)<<3)|(s&7)
CRC32 d,[b]             ::  ::  0xf2,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf1,((d&7)<<3)|(b&7)
CRC32 d,[b+!o]B         ::  ::  0xf2,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf1,0x40|((d&7)<<3)|(b&7),(o&0xff)
CRC32 d,[b+!o]          ::  ::  0xf2,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf1,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
CRC32 DWORD d,s         ::  ::  0xf2,;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0x38,0xf1,0xc0|((d&7)<<3)|(s&7)
CRC32 DWORD d,[b]       ::  ::  0xf2,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0x38,0xf1,((d&7)<<3)|(b&7)
CRC32 BYTE d,s          ::  ::  0xf2,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0x38,0xf0,0xc0|((d&7)<<3)|(s&7)
CRC32 BYTE d,[b]        ::  ::  0xf2,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf0,((d&7)<<3)|(b&7)
CRC32 BYTE d,[b+!o]B    ::  ::  0xf2,0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf0,0x40|((d&7)<<3)|(b&7),(o&0xff)

/* ====================== RDRAND / RDSEED ====================== */
RDRAND d                ::  ::  0x48|((d&8)>>3),0x0f,0xc7,0xf0|(d&7)
RDRAND DWORD d          ::  ::  ;((d&8)?0x41:0),0x0f,0xc7,0xf0|(d&7)
RDRAND WORD d           ::  ::  0x66,;((d&8)?0x41:0),0x0f,0xc7,0xf0|(d&7)
RDSEED d                ::  ::  0x48|((d&8)>>3),0x0f,0xc7,0xf8|(d&7)
RDSEED DWORD d          ::  ::  ;((d&8)?0x41:0),0x0f,0xc7,0xf8|(d&7)
RDSEED WORD d           ::  ::  0x66,;((d&8)?0x41:0),0x0f,0xc7,0xf8|(d&7)

/* ====================== MOVBE ====================== */
MOVBE d,[b]             ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf0,((d&7)<<3)|(b&7)
MOVBE d,[b+!o]B         ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf0,0x40|((d&7)<<3)|(b&7),(o&0xff)
MOVBE d,[b+!o]          ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0x38,0xf0,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
MOVBE DWORD d,[b]       ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x0f,0x38,0xf0,((d&7)<<3)|(b&7)
MOVBE [b],s             ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0x38,0xf1,((s&7)<<3)|(b&7)
MOVBE [b+!o]B,s         ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0x38,0xf1,0x40|((s&7)<<3)|(b&7),(o&0xff)
MOVBE [b+!o],s          ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0x38,0xf1,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
MOVBE DWORD [b],s       ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x0f,0x38,0xf1,((s&7)<<3)|(b&7)


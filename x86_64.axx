CALL [b] ::  ::  ;((b&8)?0x41:0),0xff,0x10|(b&7)
RET      ::  ::  0xc3
RET !i   ::  ::  0xc2,@@[2,*(i,%%)]
RETF     ::  ::  0xcb
RETF !i  ::  ::  0xca,@@[2,*(i,%%)]


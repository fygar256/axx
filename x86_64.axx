/* ========================================
   x86_64 完全パターンファイル for axx  v4.0

   変数規約:
     d,s  = 64-bit GPR (0=RAX..15=R15)
     b    = ベースレジスタ (メモリ間接)
     x,y,z= XMM/YMM (0..15)
     !i   = 8/32bit即値
     !e   = 64bit即値
     !a   = ラベル/アドレス
   注: RSP(4)/R12(12)の[b]はSIB必要で非対応
       AH/BH/CH/DH と REX は同時使用不可
   ======================================== */

/* ====================== レジスタ定義 ====================== */
.setsym::RAX::0
.setsym::RCX::1
.setsym::RDX::2
.setsym::RBX::3
.setsym::RSP::4
.setsym::RBP::5
.setsym::RSI::6
.setsym::RDI::7
.setsym::R8::8
.setsym::R9::9
.setsym::R10::10
.setsym::R11::11
.setsym::R12::12
.setsym::R13::13
.setsym::R14::14
.setsym::R15::15

.setsym::EAX::0
.setsym::ECX::1
.setsym::EDX::2
.setsym::EBX::3
.setsym::ESP::4
.setsym::EBP::5
.setsym::ESI::6
.setsym::EDI::7
.setsym::R8D::8
.setsym::R9D::9
.setsym::R10D::10
.setsym::R11D::11
.setsym::R12D::12
.setsym::R13D::13
.setsym::R14D::14
.setsym::R15D::15

.setsym::AX::0
.setsym::CX::1
.setsym::DX::2
.setsym::BX::3
.setsym::SP::4
.setsym::BP::5
.setsym::SI::6
.setsym::DI::7
.setsym::R8W::8
.setsym::R9W::9
.setsym::R10W::10
.setsym::R11W::11
.setsym::R12W::12
.setsym::R13W::13
.setsym::R14W::14
.setsym::R15W::15

.setsym::AL::0
.setsym::CL::1
.setsym::DL::2
.setsym::BL::3
.setsym::SPL::4
.setsym::BPL::5
.setsym::SIL::6
.setsym::DIL::7
.setsym::R8B::8
.setsym::R9B::9
.setsym::R10B::10
.setsym::R11B::11
.setsym::R12B::12
.setsym::R13B::13
.setsym::R14B::14
.setsym::R15B::15
.setsym::AH::4
.setsym::CH::5
.setsym::DH::6
.setsym::BH::7

.setsym::XMM0::0
.setsym::XMM1::1
.setsym::XMM2::2
.setsym::XMM3::3
.setsym::XMM4::4
.setsym::XMM5::5
.setsym::XMM6::6
.setsym::XMM7::7
.setsym::XMM8::8
.setsym::XMM9::9
.setsym::XMM10::10
.setsym::XMM11::11
.setsym::XMM12::12
.setsym::XMM13::13
.setsym::XMM14::14
.setsym::XMM15::15

.setsym::YMM0::0
.setsym::YMM1::1
.setsym::YMM2::2
.setsym::YMM3::3
.setsym::YMM4::4
.setsym::YMM5::5
.setsym::YMM6::6
.setsym::YMM7::7
.setsym::YMM8::8
.setsym::YMM9::9
.setsym::YMM10::10
.setsym::YMM11::11
.setsym::YMM12::12
.setsym::YMM13::13
.setsym::YMM14::14
.setsym::YMM15::15

.setsym::ES::0
.setsym::CS::1
.setsym::SS::2
.setsym::DS::3
.setsym::FS::4
.setsym::GS::5

/* ====================== データ定義 ====================== */
DB !e  ::  ::  e
DW !e  ::  ::  @@[2,*(e,%%)]
DD !e  ::  ::  @@[4,*(e,%%)]
DQ !e  ::  ::  @@[8,*(e,%%)]

/* ====================== MOV ====================== */
/* --- RIP相対 --- */
MOV RAX,[RIP+!d]  ::  ::  0x48,0x8b,0x05,@@[4,*(d-$.,%%)]
MOV d,[RIP+!a]    ::  ::  0x48|((d&8)>>1),0x8b,((d&7)<<3)|0x05,@@[4,*(a-$.,%%)]
/* --- 64bit r/r (store: opcode 0x89, REX.R=src, REX.B=dst) --- */
MOV d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x89,0xc0|(d&7)|((s&7)<<3)
/* --- 64bit r←imm64 --- */
/* --- 64bit r←imm32 (符号拡張) --- */
MOV d,!i  ::  ::  0x48|((d&8)>>3),0xc7,0xc0|(d&7),@@[4,*(i,%%)]
/* --- 64bit r←imm64 (MOV d,!e は明示的64bit値) --- */
MOV d,!e  ::  ::  0x48|((d&8)>>3),0xb8|(d&7),@@[8,*(e,%%)]
/* --- 64bit load/store [b] --- */
MOV d,[b]    ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8b,((d&7)<<3)|(b&7)
MOV [b],s    ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x89,((s&7)<<3)|(b&7)
MOV d,[b+!o]   ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8b,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
MOV [b+!o],s   ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x89,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
MOV d,[b+!o]B  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8b,0x40|((d&7)<<3)|(b&7),(o&0xff)
MOV [b+!o]B,s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x89,0x40|((s&7)<<3)|(b&7),(o&0xff)
/* --- 32bit --- */
MOV DWORD d,s    ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x89,0xc0|(d&7)|((s&7)<<3)
MOV DWORD d,!e   ::  ::  ;((d&8)?0x41:0),0xb8|(d&7),@@[4,*(e,%%)]
MOV DWORD d,[b]  ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8b,((d&7)<<3)|(b&7)
MOV DWORD [b],s  ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x89,((s&7)<<3)|(b&7)
MOV DWORD d,[b+!o]  ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8b,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
MOV DWORD [b+!o],s  ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x89,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
/* --- 16bit --- */
MOV WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x89,0xc0|(d&7)|((s&7)<<3)
MOV WORD d,!e  ::  ::  0x66,;((d&8)?0x41:0),0xb8|(d&7),@@[2,*(e,%%)]
MOV WORD d,[b] ::  ::  0x66,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8b,((d&7)<<3)|(b&7)
MOV WORD [b],s ::  ::  0x66,;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x89,((s&7)<<3)|(b&7)
/* --- 8bit --- */
MOV BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x88,0xc0|(d&7)|((s&7)<<3)
MOV BYTE d,!e  ::  ::  ;((d&8)?0x41:0),0xb0|(d&7),(e&0xff)
MOV BYTE d,[b] ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8a,((d&7)<<3)|(b&7)
MOV BYTE [b],s ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x88,((s&7)<<3)|(b&7)
MOV BYTE d,[b+!o]  ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8a,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
MOV BYTE [b+!o],s  ::  ::  ;(((s|b)&8)?(0x40|((s&8)>>1)|((b&8)>>3)):0),0x88,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
/* --- SIB [sym+reg] --- */
MOV BYTE  d,[!s\+r]  ::  ::  ;((r&8)?0x42:0),0x8a,0x04|((d&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]
MOV BYTE  [!s\+r],d  ::  ::  ;((r&8)?0x42:0),0x88,0x04|((d&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]
INC BYTE  [!s\+r]    ::  ::  ;((r&8)?0x42:0),0xfe,0x04,((r&7)<<3)|5,@@[4,*(s,%%)]
DEC BYTE  [!s\+r]    ::  ::  ;((r&8)?0x42:0),0xfe,0x0c,((r&7)<<3)|5,@@[4,*(s,%%)]
CMP BYTE  [!s\+r],!i ::  ::  ;((r&8)?0x42:0),0x80,0x3c,((r&7)<<3)|5,@@[4,*(s,%%)],i

/* ====================== MOVSX / MOVZX / MOVSXD ====================== */
MOVSXD d,s          ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x63,0xc0|((d&7)<<3)|(s&7)
MOVSXD d,[b]        ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x63,((d&7)<<3)|(b&7)
MOVSX WORD d,s      ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbf,0xc0|((d&7)<<3)|(s&7)
MOVSX BYTE d,s      ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbe,0xc0|((d&7)<<3)|(s&7)
MOVZX WORD d,s      ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xb7,0xc0|((d&7)<<3)|(s&7)
MOVZX BYTE d,s      ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xb6,0xc0|((d&7)<<3)|(s&7)
MOVSX DWORD WORD d,s ::  ::  ;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xbf,0xc0|((d&7)<<3)|(s&7)
MOVSX DWORD BYTE d,s ::  ::  ;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xbe,0xc0|((d&7)<<3)|(s&7)
MOVZX DWORD WORD d,s ::  ::  ;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xb7,0xc0|((d&7)<<3)|(s&7)
MOVZX DWORD BYTE d,s ::  ::  ;(((d|s)&8)?(0x40|((d&8)>>1)|((s&8)>>3)):0),0x0f,0xb6,0xc0|((d&7)<<3)|(s&7)

/* ====================== LEA ====================== */
LEA d,[RIP+!a]    ::  ::  0x48|((d&8)>>1),0x8d,((d&7)<<3)|0x05,@@[4,*(a-$.,%%)]
LEA d,[b]         ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8d,((d&7)<<3)|(b&7)
LEA d,[b+!o]      ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8d,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
LEA d,[b+!o]B     ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8d,0x40|((d&7)<<3)|(b&7),(o&0xff)
LEA d,[s+t*!h\+!o]B  ::  ::  0x48|((d&8)>>1)|((t&8)>>2)|((s&8)>>3),0x8d,0x40|((d&7)<<3)|4,((!h==1?0:(!h==2?1:(!h==4?2:3)))<<6)|((t&7)<<3)|(s&7),(o&0xff)
LEA d,[s+t*!h]    ::  ::  0x48|((d&8)>>1)|((t&8)>>2)|((s&8)>>3),0x8d,0x00|((d&7)<<3)|4,((!h==1?0:(!h==2?1:(!h==4?2:3)))<<6)|((t&7)<<3)|(s&7)

/* ====================== PUSH / POP ====================== */
PUSH d   ::  ::  ;((d&8)?0x41:0),0x50|(d&7)
POP  d   ::  ::  ;((d&8)?0x41:0),0x58|(d&7)
PUSH !e  ::  ::  0x68,@@[4,*(e,%%)]
PUSH8 !e ::  ::  0x6a,(e&0xff)

/* ====================== ALU: ADD ADC SUB SBB AND OR XOR ====================== */
/* ADD */
ADD d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x01,0xc0|(d&7)|((s&7)<<3)
ADD d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xc0|(d&7),@@[4,*(i,%%)]
ADD8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xc0|(d&7),(i&0xff)
ADD d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x03,((d&7)<<3)|(b&7)
ADD [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x01,((s&7)<<3)|(b&7)
ADD DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x01,0xc0|(d&7)|((s&7)<<3)
ADD DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xc0|(d&7),@@[4,*(i,%%)]
ADD8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xc0|(d&7),(i&0xff)
ADD WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x01,0xc0|(d&7)|((s&7)<<3)
ADD BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x00,0xc0|(d&7)|((s&7)<<3)
ADD BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xc0|(d&7),(i&0xff)
ADD QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xc0|(b&7),@@[4,*(i,%%)]
ADD8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xc0|(b&7),(i&0xff)
/* ADC */
ADC d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x11,0xc0|(d&7)|((s&7)<<3)
ADC d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xd0|(d&7),@@[4,*(i,%%)]
ADC8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xd0|(d&7),(i&0xff)
ADC d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x13,((d&7)<<3)|(b&7)
ADC [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x11,((s&7)<<3)|(b&7)
ADC DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x11,0xc0|(d&7)|((s&7)<<3)
ADC DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xd0|(d&7),@@[4,*(i,%%)]
ADC8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xd0|(d&7),(i&0xff)
ADC WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x11,0xc0|(d&7)|((s&7)<<3)
ADC BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x10,0xc0|(d&7)|((s&7)<<3)
ADC BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xd0|(d&7),(i&0xff)
ADC QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xd0|(b&7),@@[4,*(i,%%)]
ADC8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xd0|(b&7),(i&0xff)
/* SUB */
SUB d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x29,0xc0|(d&7)|((s&7)<<3)
SUB d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xe8|(d&7),@@[4,*(i,%%)]
SUB8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xe8|(d&7),(i&0xff)
SUB d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x2b,((d&7)<<3)|(b&7)
SUB [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x29,((s&7)<<3)|(b&7)
SUB DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x29,0xc0|(d&7)|((s&7)<<3)
SUB DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xe8|(d&7),@@[4,*(i,%%)]
SUB8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xe8|(d&7),(i&0xff)
SUB WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x29,0xc0|(d&7)|((s&7)<<3)
SUB BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x28,0xc0|(d&7)|((s&7)<<3)
SUB BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xe8|(d&7),(i&0xff)
SUB QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xe8|(b&7),@@[4,*(i,%%)]
SUB8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xe8|(b&7),(i&0xff)
/* SBB */
SBB d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x19,0xc0|(d&7)|((s&7)<<3)
SBB d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xd8|(d&7),@@[4,*(i,%%)]
SBB8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xd8|(d&7),(i&0xff)
SBB d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x1b,((d&7)<<3)|(b&7)
SBB [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x19,((s&7)<<3)|(b&7)
SBB DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x19,0xc0|(d&7)|((s&7)<<3)
SBB DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xd8|(d&7),@@[4,*(i,%%)]
SBB8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xd8|(d&7),(i&0xff)
SBB WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x19,0xc0|(d&7)|((s&7)<<3)
SBB BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x18,0xc0|(d&7)|((s&7)<<3)
SBB BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xd8|(d&7),(i&0xff)
SBB QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xd8|(b&7),@@[4,*(i,%%)]
SBB8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xd8|(b&7),(i&0xff)
/* AND */
AND d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x21,0xc0|(d&7)|((s&7)<<3)
AND d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xe0|(d&7),@@[4,*(i,%%)]
AND8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xe0|(d&7),(i&0xff)
AND d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x23,((d&7)<<3)|(b&7)
AND [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x21,((s&7)<<3)|(b&7)
AND DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x21,0xc0|(d&7)|((s&7)<<3)
AND DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xe0|(d&7),@@[4,*(i,%%)]
AND8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xe0|(d&7),(i&0xff)
AND WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x21,0xc0|(d&7)|((s&7)<<3)
AND BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x20,0xc0|(d&7)|((s&7)<<3)
AND BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xe0|(d&7),(i&0xff)
AND QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xe0|(b&7),@@[4,*(i,%%)]
AND8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xe0|(b&7),(i&0xff)
/* OR */
OR d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x09,0xc0|(d&7)|((s&7)<<3)
OR d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xc8|(d&7),@@[4,*(i,%%)]
OR8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xc8|(d&7),(i&0xff)
OR d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0b,((d&7)<<3)|(b&7)
OR [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x09,((s&7)<<3)|(b&7)
OR DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x09,0xc0|(d&7)|((s&7)<<3)
OR DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xc8|(d&7),@@[4,*(i,%%)]
OR8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xc8|(d&7),(i&0xff)
OR WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x09,0xc0|(d&7)|((s&7)<<3)
OR BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x08,0xc0|(d&7)|((s&7)<<3)
OR BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xc8|(d&7),(i&0xff)
OR QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xc8|(b&7),@@[4,*(i,%%)]
OR8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xc8|(b&7),(i&0xff)
/* XOR */
XOR d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x31,0xc0|(d&7)|((s&7)<<3)
XOR d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xf0|(d&7),@@[4,*(i,%%)]
XOR8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xf0|(d&7),(i&0xff)
XOR d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x33,((d&7)<<3)|(b&7)
XOR [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x31,((s&7)<<3)|(b&7)
XOR DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x31,0xc0|(d&7)|((s&7)<<3)
XOR DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xf0|(d&7),@@[4,*(i,%%)]
XOR8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xf0|(d&7),(i&0xff)
XOR WORD d,s   ::  ::  0x66,;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x31,0xc0|(d&7)|((s&7)<<3)
XOR BYTE d,s   ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x30,0xc0|(d&7)|((s&7)<<3)
XOR BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xf0|(d&7),(i&0xff)
XOR QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x81,0xf0|(b&7),@@[4,*(i,%%)]
XOR8 QWORD [b],!i ::  ::  0x48|((b&8)>>3),0x83,0xf0|(b&7),(i&0xff)
/* CMP */
CMP d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x39,0xc0|(d&7)|((s&7)<<3)
CMP d,!i   ::  ::  0x48|((d&8)>>3),0x81,0xf8|(d&7),@@[4,*(i,%%)]
CMP8 d,!i  ::  ::  0x48|((d&8)>>3),0x83,0xf8|(d&7),(i&0xff)
CMP d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x3b,((d&7)<<3)|(b&7)
CMP [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x39,((s&7)<<3)|(b&7)
CMP DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x39,0xc0|(d&7)|((s&7)<<3)
CMP DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x81,0xf8|(d&7),@@[4,*(i,%%)]
CMP8 DWORD d,!i ::  ::  ;((d&8)?0x41:0),0x83,0xf8|(d&7),(i&0xff)
CMP BYTE [b],!i ::  ::  ;((b&8)?0x41:0),0x80,0x38|(b&7),(i&0xff)
CMP BYTE d,!i   ::  ::  ;((d&8)?0x41:0),0x80,0xf8|(d&7),(i&0xff)
CMP BYTE d,s    ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x38,0xc0|(d&7)|((s&7)<<3)
CMP BYTE d,[b]  ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x3a,((d&7)<<3)|(b&7)
/* TEST */
TEST d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x85,0xc0|(d&7)|((s&7)<<3)
TEST d,!i   ::  ::  0x48|((d&8)>>3),0xf7,0xc0|(d&7),@@[4,*(i,%%)]
TEST DWORD d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x85,0xc0|(d&7)|((s&7)<<3)
TEST DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xf7,0xc0|(d&7),@@[4,*(i,%%)]
TEST BYTE d,s  ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x84,0xc0|(d&7)|((s&7)<<3)
TEST BYTE d,!i ::  ::  ;((d&8)?0x41:0),0xf6,0xc0|(d&7),(i&0xff)
TEST BYTE [b],!i ::  ::  ;((b&8)?0x41:0),0xf6,0x00|(b&7),(i&0xff)

/* ====================== MUL / IMUL / DIV / IDIV ====================== */
MUL s          ::  ::  0x48|((s&8)>>3),0xf7,0xe0|(s&7)
IMUL s         ::  ::  0x48|((s&8)>>3),0xf7,0xe8|(s&7)
DIV s          ::  ::  0x48|((s&8)>>3),0xf7,0xf0|(s&7)
IDIV s         ::  ::  0x48|((s&8)>>3),0xf7,0xf8|(s&7)
IMUL d,s       ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xaf,0xc0|((d&7)<<3)|(s&7)
IMUL d,[b]     ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xaf,((d&7)<<3)|(b&7)
IMUL d,s,!i    ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x69,0xc0|((d&7)<<3)|(s&7),@@[4,*(i,%%)]
IMUL8 d,s,!i   ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x6b,0xc0|((d&7)<<3)|(s&7),(i&0xff)
MUL DWORD s    ::  ::  ;((s&8)?0x41:0),0xf7,0xe0|(s&7)
IMUL DWORD s   ::  ::  ;((s&8)?0x41:0),0xf7,0xe8|(s&7)
DIV DWORD s    ::  ::  ;((s&8)?0x41:0),0xf7,0xf0|(s&7)
IDIV DWORD s   ::  ::  ;((s&8)?0x41:0),0xf7,0xf8|(s&7)

/* ====================== INC / DEC / NEG / NOT ====================== */
INC d  ::  ::  0x48|((d&8)>>3),0xff,0xc0|(d&7)
DEC d  ::  ::  0x48|((d&8)>>3),0xff,0xc8|(d&7)
NEG d  ::  ::  0x48|((d&8)>>3),0xf7,0xd8|(d&7)
NOT d  ::  ::  0x48|((d&8)>>3),0xf7,0xd0|(d&7)
INC DWORD d  ::  ::  ;((d&8)?0x41:0),0xff,0xc0|(d&7)
DEC DWORD d  ::  ::  ;((d&8)?0x41:0),0xff,0xc8|(d&7)
NEG DWORD d  ::  ::  ;((d&8)?0x41:0),0xf7,0xd8|(d&7)
NOT DWORD d  ::  ::  ;((d&8)?0x41:0),0xf7,0xd0|(d&7)
INC BYTE [b]  ::  ::  ;((b&8)?0x41:0),0xfe,0x00|(b&7)
DEC BYTE [b]  ::  ::  ;((b&8)?0x41:0),0xfe,0x08|(b&7)
INC WORD [b]  ::  ::  0x66,;((b&8)?0x41:0),0xff,0x00|(b&7)
DEC WORD [b]  ::  ::  0x66,;((b&8)?0x41:0),0xff,0x08|(b&7)
INC QWORD [b] ::  ::  0x48|((b&8)>>3),0xff,0x00|(b&7)
DEC QWORD [b] ::  ::  0x48|((b&8)>>3),0xff,0x08|(b&7)
NEG QWORD [b] ::  ::  0x48|((b&8)>>3),0xf7,0x18|(b&7)
NOT QWORD [b] ::  ::  0x48|((b&8)>>3),0xf7,0x10|(b&7)

/* ====================== CBW / CWDE / CDQE / CWD / CDQ / CQO ====================== */
CBW   ::  ::  0x66,0x98
CWDE  ::  ::  0x98
CDQE  ::  ::  0x48,0x98
CWD   ::  ::  0x66,0x99
CDQ   ::  ::  0x99
CQO   ::  ::  0x48,0x99

/* ====================== シフト / ローテート ====================== */
/* ROL */
ROL d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xc0|(d&7)
ROL d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xc0|(d&7),(i&0xff)
ROL d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xc0|(d&7)
ROL DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xc0|(d&7),(i&0xff)
ROL DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xc0|(d&7)
ROL DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xc0|(d&7)
ROL WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xc0|(d&7),(i&0xff)
ROL WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xc0|(d&7)
ROL BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xc0|(d&7),(i&0xff)
ROL BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xc0|(d&7)
ROL QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x00|(b&7),(i&0xff)
ROL QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x00|(b&7)
/* ROR */
ROR d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xc8|(d&7)
ROR d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xc8|(d&7),(i&0xff)
ROR d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xc8|(d&7)
ROR DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xc8|(d&7),(i&0xff)
ROR DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xc8|(d&7)
ROR DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xc8|(d&7)
ROR WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xc8|(d&7),(i&0xff)
ROR WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xc8|(d&7)
ROR BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xc8|(d&7),(i&0xff)
ROR BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xc8|(d&7)
ROR QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x08|(b&7),(i&0xff)
ROR QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x08|(b&7)
/* RCL */
RCL d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xd0|(d&7)
RCL d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xd0|(d&7),(i&0xff)
RCL d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xd0|(d&7)
RCL DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xd0|(d&7),(i&0xff)
RCL DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xd0|(d&7)
RCL DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xd0|(d&7)
RCL WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xd0|(d&7),(i&0xff)
RCL WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xd0|(d&7)
RCL BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xd0|(d&7),(i&0xff)
RCL BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xd0|(d&7)
RCL QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x10|(b&7),(i&0xff)
RCL QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x10|(b&7)
/* RCR */
RCR d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xd8|(d&7)
RCR d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xd8|(d&7),(i&0xff)
RCR d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xd8|(d&7)
RCR DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xd8|(d&7),(i&0xff)
RCR DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xd8|(d&7)
RCR DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xd8|(d&7)
RCR WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xd8|(d&7),(i&0xff)
RCR WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xd8|(d&7)
RCR BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xd8|(d&7),(i&0xff)
RCR BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xd8|(d&7)
RCR QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x18|(b&7),(i&0xff)
RCR QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x18|(b&7)
/* SHL */
SHL d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xe0|(d&7)
SHL d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xe0|(d&7),(i&0xff)
SHL d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xe0|(d&7)
SHL DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xe0|(d&7),(i&0xff)
SHL DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xe0|(d&7)
SHL DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xe0|(d&7)
SHL WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xe0|(d&7),(i&0xff)
SHL WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xe0|(d&7)
SHL BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xe0|(d&7),(i&0xff)
SHL BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xe0|(d&7)
SHL QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x20|(b&7),(i&0xff)
SHL QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x20|(b&7)
/* SHR */
SHR d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xe8|(d&7)
SHR d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xe8|(d&7),(i&0xff)
SHR d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xe8|(d&7)
SHR DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xe8|(d&7),(i&0xff)
SHR DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xe8|(d&7)
SHR DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xe8|(d&7)
SHR WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xe8|(d&7),(i&0xff)
SHR WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xe8|(d&7)
SHR BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xe8|(d&7),(i&0xff)
SHR BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xe8|(d&7)
SHR QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x28|(b&7),(i&0xff)
SHR QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x28|(b&7)
/* SAR */
SAR d,CL       ::  ::  0x48|((d&8)>>3),0xd3,0xf8|(d&7)
SAR d,!i       ::  ::  0x48|((d&8)>>3),0xc1,0xf8|(d&7),(i&0xff)
SAR d,1        ::  ::  0x48|((d&8)>>3),0xd1,0xf8|(d&7)
SAR DWORD d,!i ::  ::  ;((d&8)?0x41:0),0xc1,0xf8|(d&7),(i&0xff)
SAR DWORD d,CL ::  ::  ;((d&8)?0x41:0),0xd3,0xf8|(d&7)
SAR DWORD d,1  ::  ::  ;((d&8)?0x41:0),0xd1,0xf8|(d&7)
SAR WORD d,!i  ::  ::  0x66,;((d&8)?0x41:0),0xc1,0xf8|(d&7),(i&0xff)
SAR WORD d,CL  ::  ::  0x66,;((d&8)?0x41:0),0xd3,0xf8|(d&7)
SAR BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0xc0,0xf8|(d&7),(i&0xff)
SAR BYTE d,CL  ::  ::  ;((d&8)?0x41:0),0xd2,0xf8|(d&7)
SAR QWORD [b],!i ::  ::  0x48|((b&8)>>3),0xc1,0x38|(b&7),(i&0xff)
SAR QWORD [b],CL ::  ::  0x48|((b&8)>>3),0xd3,0x38|(b&7)
/* SHLD / SHRD */
SHLD d,s,CL  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa5,0xc0|((s&7)<<3)|(d&7)
SHLD d,s,!i  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa4,0xc0|((s&7)<<3)|(d&7),(i&0xff)
SHRD d,s,CL  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xad,0xc0|((s&7)<<3)|(d&7)
SHRD d,s,!i  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xac,0xc0|((s&7)<<3)|(d&7),(i&0xff)

/* ====================== ビット操作 ====================== */
BSF d,s     ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
BSR d,s     ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)
POPCNT d,s  ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xb8,0xc0|((d&7)<<3)|(s&7)
LZCNT d,s   ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)
TZCNT d,s   ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
BT  d,s     ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa3,0xc0|((s&7)<<3)|(d&7)
BT  d,!i    ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xe0|(d&7),(i&0xff)
BTS d,s     ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xab,0xc0|((s&7)<<3)|(d&7)
BTS d,!i    ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xe8|(d&7),(i&0xff)
BTR d,s     ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xb3,0xc0|((s&7)<<3)|(d&7)
BTR d,!i    ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xf0|(d&7),(i&0xff)
BTC d,s     ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xbb,0xc0|((s&7)<<3)|(d&7)
BTC d,!i    ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xf8|(d&7),(i&0xff)
BSWAP d     ::  ::  0x48|((d&8)>>3),0x0f,0xc8|(d&7)
BSWAP DWORD d ::  ::  ;((d&8)?0x41:0),0x0f,0xc8|(d&7)

/* ====================== XCHG / CMPXCHG / XADD ====================== */
XCHG RAX,d     ::  ::  0x48|((d&8)>>3),0x90|(d&7)
XCHG d,RAX     ::  ::  0x48|((d&8)>>3),0x90|(d&7)
XCHG d,s       ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x87,0xc0|(d&7)|((s&7)<<3)
XCHG DWORD d,s ::  ::  ;(((s|d)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x87,0xc0|(d&7)|((s&7)<<3)
CMPXCHG d,s    ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xb1,0xc0|(d&7)|((s&7)<<3)
CMPXCHG [b],s  ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb1,((s&7)<<3)|(b&7)
CMPXCHG8B [b]  ::  ::  ;((b&8)?0x41:0),0x0f,0xc7,0x08|(b&7)
CMPXCHG16B [b] ::  ::  0x48|((b&8)>>3),0x0f,0xc7,0x08|(b&7)
XADD d,s       ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xc1,0xc0|(d&7)|((s&7)<<3)
XADD [b],s     ::  ::  0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xc1,((s&7)<<3)|(b&7)

/* ====================== LOCK プレフィックス ====================== */
LOCK_INC d  ::  ::  0xf0,0x48|((d&8)>>3),0xff,0xc0|(d&7)
LOCK_DEC d  ::  ::  0xf0,0x48|((d&8)>>3),0xff,0xc8|(d&7)
LOCK_ADD d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x01,0xc0|(d&7)|((s&7)<<3)
LOCK_SUB d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x29,0xc0|(d&7)|((s&7)<<3)
LOCK_AND d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x21,0xc0|(d&7)|((s&7)<<3)
LOCK_OR  d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x09,0xc0|(d&7)|((s&7)<<3)
LOCK_XOR d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x31,0xc0|(d&7)|((s&7)<<3)
LOCK_XADD d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xc1,0xc0|(d&7)|((s&7)<<3)
LOCK_CMPXCHG d,s  ::  ::  0xf0,0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xb1,0xc0|(d&7)|((s&7)<<3)
LOCK_INC BYTE [b]  ::  ::  0xf0,;((b&8)?0x41:0),0xfe,0x00|(b&7)
LOCK_DEC BYTE [b]  ::  ::  0xf0,;((b&8)?0x41:0),0xfe,0x08|(b&7)
LOCK_BTS QWORD [b],s  ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xab,((s&7)<<3)|(b&7)
LOCK_BTR QWORD [b],s  ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xb3,((s&7)<<3)|(b&7)
LOCK_BTC QWORD [b],s  ::  ::  0xf0,0x48|((s&8)>>1)|((b&8)>>3),0x0f,0xbb,((s&7)<<3)|(b&7)

/* ====================== 条件分岐 (near 32-bit) ====================== */

/* ====================== AVX (VEX プレフィックス 3バイト形式) ====================== */
VMOVSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|2)&0xff,0x10,0xc0|((x&7)<<3)|(z&7)
VMOVSS x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|3)&0xff,0x10,0xc0|((x&7)<<3)|(z&7)
VMOVSD x,[b]  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(b)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|2)&0xff,0x10,((x&7)<<3)|(b&7)
VMOVSS x,[b]  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(b)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|3)&0xff,0x10,((x&7)<<3)|(b&7)
VMOVAPS x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|0)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVAPD x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|1)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVUPS x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|0)&0xff,0x10,0xc0|((x&7)<<3)|(y&7)
VMOVUPD x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|1)&0xff,0x10,0xc0|((x&7)<<3)|(y&7)
VMOVDQA x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|1)&0xff,0x6f,0xc0|((x&7)<<3)|(y&7)
VMOVDQU x,y   ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(0<<2)|2)&0xff,0x6f,0xc0|((x&7)<<3)|(y&7)

/* 256bit */
VMOVAPS256 x,y  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(1<<2)|0)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVAPD256 x,y  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(1<<2)|1)&0xff,0x28,0xc0|((x&7)<<3)|(y&7)
VMOVUPS256 x,y  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(1<<2)|0)&0xff,0x10,0xc0|((x&7)<<3)|(y&7)
VMOVDQA256 x,y  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(1<<2)|1)&0xff,0x6f,0xc0|((x&7)<<3)|(y&7)
VMOVDQU256 x,y  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(y)>>3&1))&0xff,((0xf&0xf)<<3|(1<<2)|2)&0xff,0x6f,0xc0|((x&7)<<3)|(y&7)

/* スカラー算術 (3オペランド) */
VADDSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x58,0xc0|((x&7)<<3)|(z&7)
VSUBSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x5c,0xc0|((x&7)<<3)|(z&7)
VMULSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x59,0xc0|((x&7)<<3)|(z&7)
VDIVSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x5e,0xc0|((x&7)<<3)|(z&7)
VSQRTSD x,y,z ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x51,0xc0|((x&7)<<3)|(z&7)
VMINSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x5d,0xc0|((x&7)<<3)|(z&7)
VMAXSD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|2)&0xff,0x5f,0xc0|((x&7)<<3)|(z&7)
VADDSS x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|3)&0xff,0x58,0xc0|((x&7)<<3)|(z&7)
VSUBSS x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|3)&0xff,0x5c,0xc0|((x&7)<<3)|(z&7)
VMULSS x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|3)&0xff,0x59,0xc0|((x&7)<<3)|(z&7)
VDIVSS x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|3)&0xff,0x5e,0xc0|((x&7)<<3)|(z&7)
VSQRTSS x,y,z ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|3)&0xff,0x51,0xc0|((x&7)<<3)|(z&7)

/* パックド浮動小数点 */
VADDPD x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0x58,0xc0|((x&7)<<3)|(z&7)
VSUBPD x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0x5c,0xc0|((x&7)<<3)|(z&7)
VMULPD x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0x59,0xc0|((x&7)<<3)|(z&7)
VDIVPD x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0x5e,0xc0|((x&7)<<3)|(z&7)
VADDPS x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|0)&0xff,0x58,0xc0|((x&7)<<3)|(z&7)
VSUBPS x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|0)&0xff,0x5c,0xc0|((x&7)<<3)|(z&7)
VMULPS x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|0)&0xff,0x59,0xc0|((x&7)<<3)|(z&7)
VDIVPS x,y,z    ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|0)&0xff,0x5e,0xc0|((x&7)<<3)|(z&7)

VADDPD256 x,y,z ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(1<<2)|1)&0xff,0x58,0xc0|((x&7)<<3)|(z&7)
VSUBPD256 x,y,z ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(1<<2)|1)&0xff,0x5c,0xc0|((x&7)<<3)|(z&7)
VMULPD256 x,y,z ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(1<<2)|1)&0xff,0x59,0xc0|((x&7)<<3)|(z&7)
VDIVPD256 x,y,z ::  ::  0xc4,((~(x)>>3&1)<<5|0x61|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(1<<2)|1)&0xff,0x5e,0xc0|((x&7)<<3)|(z&7)

/* FMA3 */
VFMADD132PD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x62|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0x98,0xc0|((x&7)<<3)|(z&7)
VFMADD213PD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x62|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0xa8,0xc0|((x&7)<<3)|(z&7)
VFMADD231PD x,y,z  ::  ::  0xc4,((~(x)>>3&1)<<5|0x62|(~(z)>>3&1))&0xff,((~(y)&0xf)<<3|(0<<2)|1)&0xff,0xb8,0xc0|((x&7)<<3)|(z&7)

/* BMI1 / BMI2 */
ANDN d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(t)>>3&1))&0xff,(0x80|(~(s)&0xf)<<3)&0xff,0xf2,0xc0|((d&7)<<3)|(t&7)
BEXTR d,s,t  ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x80|(~(t)&0xf)<<3)&0xff,0xf7,0xc0|((d&7)<<3)|(s&7)
BLSI d,s     ::  ::  0xc4,((~(0)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x80|(~(d)&0xf)<<3)&0xff,0xf3,0xd8|(s&7)
BLSMSK d,s   ::  ::  0xc4,((~(0)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x80|(~(d)&0xf)<<3)&0xff,0xf3,0xe0|(s&7)
BLSR d,s     ::  ::  0xc4,((~(0)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x80|(~(d)&0xf)<<3)&0xff,0xf3,0xc8|(s&7)

BZHI d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x80|(~(t)&0xf)<<3)&0xff,0xf5,0xc0|((d&7)<<3)|(s&7)
MULX d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(t)>>3&1))&0xff,(0x83|(~(s)&0xf)<<3)&0xff,0xf6,0xc0|((d&7)<<3)|(t&7)
PDEP d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(t)>>3&1))&0xff,(0x83|(~(s)&0xf)<<3)&0xff,0xf5,0xc0|((d&7)<<3)|(t&7)
PEXT d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(t)>>3&1))&0xff,(0x82|(~(s)&0xf)<<3)&0xff,0xf5,0xc0|((d&7)<<3)|(t&7)
RORX d,s,!i  ::  ::  0xc4,((~(d)>>3&1)<<5|0x63|(~(s)>>3&1))&0xff,(0x83|(0xf<<3))&0xff,0xf0,0xc0|((d&7)<<3)|(s&7),(i&0xff)
SARX d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x83|(~(t)&0xf)<<3)&0xff,0xf7,0xc0|((d&7)<<3)|(s&7)
SHLX d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x81|(~(t)&0xf)<<3)&0xff,0xf7,0xc0|((d&7)<<3)|(s&7)
SHRX d,s,t   ::  ::  0xc4,((~(d)>>3&1)<<5|0x62|(~(s)>>3&1))&0xff,(0x82|(~(t)&0xf)<<3)&0xff,0xf7,0xc0|((d&7)<<3)|(s&7)

/* ====================== x87 FPU ====================== */
FLDS [b]   ::  ::  ;((b&8)?0x41:0),0xd9,0x00|(b&7)
FSTS [b]   ::  ::  ;((b&8)?0x41:0),0xd9,0x10|(b&7)
FSTPS [b]  ::  ::  ;((b&8)?0x41:0),0xd9,0x18|(b&7)
FLDL [b]   ::  ::  ;((b&8)?0x41:0),0xdd,0x00|(b&7)
FSTL [b]   ::  ::  ;((b&8)?0x41:0),0xdd,0x10|(b&7)
FSTPL [b]  ::  ::  ;((b&8)?0x41:0),0xdd,0x18|(b&7)
FLD1       ::  ::  0xd9,0xe8
FLDL2T     ::  ::  0xd9,0xe9
FLDL2E     ::  ::  0xd9,0xea
FLDPI      ::  ::  0xd9,0xeb
FLDLG2     ::  ::  0xd9,0xec
FLDLN2     ::  ::  0xd9,0xed
FLDZ       ::  ::  0xd9,0xee
FADD [b]   ::  ::  ;((b&8)?0x41:0),0xd8,0x00|(b&7)
FADDP      ::  ::  0xde,0xc1
FSUB [b]   ::  ::  ;((b&8)?0x41:0),0xd8,0x20|(b&7)
FSUBP      ::  ::  0xde,0xe9
FMUL [b]   ::  ::  ;((b&8)?0x41:0),0xd8,0x08|(b&7)
FMULP      ::  ::  0xde,0xc9
FDIV [b]   ::  ::  ;((b&8)?0x41:0),0xd8,0x30|(b&7)
FDIVP      ::  ::  0xde,0xf9
FSQRT      ::  ::  0xd9,0xfa
FABS       ::  ::  0xd9,0xe1
FCHS       ::  ::  0xd9,0xe0
FRNDINT    ::  ::  0xd9,0xfc
FCOM [b]   ::  ::  ;((b&8)?0x41:0),0xd8,0x10|(b&7)
FCOMP [b]  ::  ::  ;((b&8)?0x41:0),0xd8,0x18|(b&7)
FCOMPP     ::  ::  0xde,0xd9
FUCOM      ::  ::  0xdd,0xe1
FUCOMP     ::  ::  0xdd,0xe9
FUCOMPP    ::  ::  0xda,0xe9
FTST       ::  ::  0xd9,0xe4
FXAM       ::  ::  0xd9,0xe5
FXCH       ::  ::  0xd9,0xc9
FNOP       ::  ::  0xd9,0xd0
FWAIT      ::  ::  0x9b
FINIT      ::  ::  0x9b,0xdb,0xe3
FNINIT     ::  ::  0xdb,0xe3
FCLEX      ::  ::  0x9b,0xdb,0xe2
FNSTSW AX  ::  ::  0xdf,0xe0
FSTCW [b]  ::  ::  0x9b,;((b&8)?0x41:0),0xd9,0x38|(b&7)
FLDCW [b]  ::  ::  ;((b&8)?0x41:0),0xd9,0x28|(b&7)
FILD [b]   ::  ::  ;((b&8)?0x41:0),0xdb,0x00|(b&7)
FIST [b]   ::  ::  ;((b&8)?0x41:0),0xdb,0x10|(b&7)
FISTP [b]  ::  ::  ;((b&8)?0x41:0),0xdb,0x18|(b&7)
FISTTP [b] ::  ::  ;((b&8)?0x41:0),0xdb,0x08|(b&7)
FXSAVE [b]   ::  ::  ;((b&8)?0x41:0),0x0f,0xae,0x00|(b&7)
FXRSTOR [b]  ::  ::  ;((b&8)?0x41:0),0x0f,0xae,0x08|(b&7)
XSAVE [b]    ::  ::  ;((b&8)?0x41:0),0x0f,0xae,0x20|(b&7)
XRSTOR [b]   ::  ::  ;((b&8)?0x41:0),0x0f,0xae,0x28|(b&7)

/* ====================== IN / OUT ====================== */
IN AL,DX   ::  ::  0xec
IN AX,DX   ::  ::  0x66,0xed
IN EAX,DX  ::  ::  0xed
IN AL,!i   ::  ::  0xe4,(i&0xff)
IN EAX,!i  ::  ::  0xe5,(i&0xff)
OUT DX,AL  ::  ::  0xee
OUT DX,EAX ::  ::  0xef
OUT !i,AL  ::  ::  0xe6,(i&0xff)
OUT !i,EAX ::  ::  0xe7,(i&0xff)

/* ====================== データ定義 ====================== */
DB !e  ::  ::  e
DW !e  ::  ::  @@[2,*(e,%%)]
DD !e  ::  ::  @@[4,*(e,%%)]
DQ !e  ::  ::  @@[8,*(e,%%)]
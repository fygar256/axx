/* ====================== MOVアドレッシング・モード ====================== */
/* MOV RAX,[rip+foo] - RIP相対 */
MOV RAX,[RIP+!d] :: :: 0x48,0x8b,0x05,@@[4,*(d-$.,%%)]

/* MOV r64,r64 - レジスタ間 */
MOV d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x89,0xc0|(d&7)|((s&7)<<3)

/* MOV r64,[r/m64] - メモリロード */
MOV d,[b]  ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8b,((d&7)<<3)|(b&7)

/* MOV [r/m64],r64 - メモリストア */
MOV [d],s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x89,((s&7)<<3)|(d&7)

/* MOV r64,imm64 */
MOV d,!e  ::  ::  0x48|((d&8)>>3),0xb8|(d&7),@@[8,*(e,%%)]

/* MOV DWORD r32,[r/m32] */
MOV DWORD d,[b]  ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8b,((d&7)<<3)|(b&7)

/* MOV DWORD [r/m32],r32 */
MOV DWORD [d],s  ::  ::  ;(((d|s)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x89,((s&7)<<3)|(d&7)

/* MOV DWORD r32,imm32 */
MOV DWORD d,!e  ::  ::  ;((d&8)?(0x41):0),0xb8|(d&7),@@[4,*(e,%%)]

/* MOV BYTE r8,[r/m8] */
MOV BYTE d,[b]  ::  ::  ;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8a,((d&7)<<3)|(b&7)

/* MOV BYTE [r/m8],r8 */
MOV BYTE [d],s  ::  ::  ;(((d|s)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x88,((s&7)<<3)|(d&7)

/* MOV BYTE r8,imm8 */
MOV BYTE d,!e  ::  ::  0xb0|(d&7),(e&0xff)

/* MOV WORD r16,[r/m16] */
MOV WORD d,[b]  ::  ::  0x66,;(((d|b)&8)?(0x40|((d&8)>>1)|((b&8)>>3)):0),0x8b,((d&7)<<3)|(b&7)

/* MOV WORD [r/m16],r16 */
MOV WORD [d],s  ::  ::  0x66,;(((d|s)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x89,((s&7)<<3)|(d&7)

/* MOV WORD r16,imm16 */
MOV WORD d,!e  ::  ::  0x66,0xb8|(d&7),@@[2,*(e,%%)]

/* ====================== SIB アドレッシング・モード (複雑な場合) ====================== */
/* [base + index*scale + disp] addressing */
/* MOV r64,[base+index*scale+disp32] */
MOV d,[!b+!i\*!s+!o] :: :: 0x48|((d&8)>>1)|((i&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3)|4,(((!s==1?0:(!s==2?1:(!s==4?2:3)))<<6)|((i&7)<<3)|(b&7)),@@[4,*(o,%%)]

/* MOV [base+index*scale+disp32],r64 */
MOV [!b+!i\*!s+!o],d :: :: 0x48|((d&8)>>1)|((i&8)>>2)|((b&8)>>3),0x89,0x84|((d&7)<<3)|4,(((!s==1?0:(!s==2?1:(!s==4?2:3)))<<6)|((i&7)<<3)|(b&7)),@@[4,*(o,%%)]

/* [symbol+reg] SIBアドレッシング */
INC BYTE  [!s\+r]      ::  ::  ;((r&8)?0x42:0),0xfe,0x04,((r&7)<<3)|5,@@[4,*(s,%%)]
DEC BYTE  [!s\+r]      ::  ::  ;((r&8)?0x42:0),0xfe,0x0c,((r&7)<<3)|5,@@[4,*(s,%%)]
CMP BYTE  [!s\+r],!i   ::  ::  ;((r&8)?0x42:0),0x80,0x3c,((r&7)<<3)|5,@@[4,*(s,%%)],(i&0xff)
MOV BYTE  d,[!s\+r]    ::  ::  ;((r&8)?0x42:0),0x8a,0x04|((d&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]
MOV BYTE  [!s\+r],d    ::  ::  ;((r&8)?0x42:0),0x88,0x04|((d&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]

/* ====================== 算術命令 ====================== */
/* ADD */
ADD d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x01,0xc0|(d&7)|((s&7)<<3)
ADD d,!i  ::  ::  0x48|((d&8)>>3),0x81,0xc0|(d&7),@@[4,*(i,%%)]
ADD [d],s ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x01,((s&7)<<3)|(d&7)

ADD DWORD d,s  ::  ::  ;(((d|s)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x01,0xc0|(d&7)|((s&7)<<3)
ADD BYTE d,s   ::  ::  ;(((d|s)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x00,0xc0|(d&7)|((s&7)<<3)

/* SUB */
SUB d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x29,0xc0|(d&7)|((s&7)<<3)
SUB d,!i  ::  ::  0x48|((d&8)>>3),0x81,0xe8|(d&7),@@[4,*(i,%%)]
SUB [d],s ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x29,((s&7)<<3)|(d&7)

/* MUL (unsigned) */
MUL d  ::  ::  0x48|((d&8)>>3),0xf7,0xe0|(d&7)
MUL [d] ::  ::  0x48|((d&8)>>3),0xf7,0x20|(d&7)

/* IMUL (signed) */
IMUL d  ::  ::  0x48|((d&8)>>3),0xf7,0xe8|(d&7)
IMUL d,s ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xaf,0xc0|(d&7)|((s&7)<<3)
IMUL d,s,!i ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x69,0xc0|(d&7)|((s&7)<<3),@@[4,*(i,%%)]

/* DIV (unsigned) */
DIV d  ::  ::  0x48|((d&8)>>3),0xf7,0xf0|(d&7)

/* IDIV (signed) */
IDIV d  ::  ::  0x48|((d&8)>>3),0xf7,0xf8|(d&7)

/* INC/DEC */
INC d  ::  ::  0x48|((d&8)>>3),0xff,0xc0|(d&7)
DEC d  ::  ::  0x48|((d&8)>>3),0xff,0xc8|(d&7)

INC DWORD d ::  ::  ;((d&8)?0x41:0),0xff,0xc0|(d&7)
DEC DWORD d ::  ::  ;((d&8)?0x41:0),0xff,0xc8|(d&7)

INC BYTE [b]  ::  ::  ;((b&8)?0x41:0),0xfe,0x00|(b&7)
DEC BYTE [b]  ::  ::  ;((b&8)?0x41:0),0xfe,0x08|(b&7)

/* NEG */
NEG d  ::  ::  0x48|((d&8)>>3),0xf7,0xd8|(d&7)

/* ====================== 論理命令 ====================== */
/* AND */
AND d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x21,0xc0|(d&7)|((s&7)<<3)
AND d,!i  ::  ::  0x48|((d&8)>>3),0x81,0xe0|(d&7),@@[4,*(i,%%)]

/* OR */
OR d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x09,0xc0|(d&7)|((s&7)<<3)
OR d,!i  ::  ::  0x48|((d&8)>>3),0x81,0xc8|(d&7),@@[4,*(i,%%)]

/* XOR */
XOR d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x31,0xc0|(d&7)|((s&7)<<3)
XOR d,!i  ::  ::  0x48|((d&8)>>3),0x81,0xf0|(d&7),@@[4,*(i,%%)]

/* NOT */
NOT d  ::  ::  0x48|((d&8)>>3),0xf7,0xd0|(d&7)

/* ====================== シフト命令 ====================== */
/* SAL/SHL */
SAL d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xe0|(d&7),(i&0xff)
SAL d,CL  ::  ::  0x48|((d&8)>>3),0xd3,0xe0|(d&7)

/* SHL (alias for SAL) */
SHL d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xe0|(d&7),(i&0xff)
SHL d,CL  ::  ::  0x48|((d&8)>>3),0xd3,0xe0|(d&7)

/* SAR */
SAR d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xf8|(d&7),(i&0xff)
SAR d,CL  ::  ::  0x48|((d&8)>>3),0xd3,0xf8|(d&7)

/* SHR */
SHR d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xe8|(d&7),(i&0xff)
SHR d,CL  ::  ::  0x48|((d&8)>>3),0xd3,0xe8|(d&7)

/* RCL, RCR, ROL, ROR */
RCL d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xd0|(d&7),(i&0xff)
RCR d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xd8|(d&7),(i&0xff)
ROL d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xc0|(d&7),(i&0xff)
ROR d,!i  ::  ::  0x48|((d&8)>>3),0xc1,0xc8|(d&7),(i&0xff)

/* ====================== 比較とテスト命令 ====================== */
/* CMP */
CMP d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x39,0xc0|(d&7)|((s&7)<<3)
CMP d,!i  ::  ::  0x48|((d&8)>>3),0x81,0xf8|(d&7),@@[4,*(i,%%)]
CMP [d],s ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x39,((s&7)<<3)|(d&7)

CMP DWORD d,s  ::  ::  ;(((d|s)&8)?(0x40|((s&8)>>1)|((d&8)>>3)):0),0x39,0xc0|(d&7)|((s&7)<<3)
CMP DWORD d,!i  ::  ::  ;((d&8)?(0x41):0),0x81,0xf8|(d&7),@@[4,*(i,%%)]

CMP BYTE d,!i  ::  ::  ;((d&8)?0x41:0),0x80,0xf8|(d&7),(i&0xff)
CMP BYTE [b],!i  ::  ::  ;((b&8)?0x41:0),0x80,0x38|(b&7),(i&0xff)

/* TEST */
TEST d,s  ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x85,0xc0|(d&7)|((s&7)<<3)
TEST d,!i  ::  ::  0x48|((d&8)>>3),0xf7,0xc0|(d&7),@@[4,*(i,%%)]

/* ====================== ビット操作命令 ====================== */
/* BSF/BSR */
BSF d,s     ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)
BSR d,s     ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)

/* POPCNT */
POPCNT d,s  ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xb8,0xc0|((d&7)<<3)|(s&7)

/* LZCNT */
LZCNT d,s   ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbd,0xc0|((d&7)<<3)|(s&7)

/* TZCNT */
TZCNT d,s   ::  ::  0xf3,0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xbc,0xc0|((d&7)<<3)|(s&7)

/* BT/BTS/BTR/BTC */
BT d,s       ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xa3,0xc0|((s&7)<<3)|(d&7)
BT d,!i      ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xe0|(d&7),(i&0xff)
BTS d,s      ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xab,0xc0|((s&7)<<3)|(d&7)
BTS d,!i     ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xe8|(d&7),(i&0xff)
BTR d,s      ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xb3,0xc0|((s&7)<<3)|(d&7)
BTR d,!i     ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xf0|(d&7),(i&0xff)
BTC d,s      ::  ::  0x48|((s&8)>>1)|((d&8)>>3),0x0f,0xbb,0xc0|((s&7)<<3)|(d&7)
BTC d,!i     ::  ::  0x48|((d&8)>>3),0x0f,0xba,0xf8|(d&7),(i&0xff)

/* BSWAP */
BSWAP d      ::  ::  0x48|((d&8)>>3),0x0f,0xc8|(d&7)
BSWAP DWORD d ::  ::  ;((d&8)?0x41:0),0x0f,0xc8|(d&7)

/* ====================== LEA (Load Effective Address) ====================== */
LEA d,[RIP+!a]  ::  ::  0x48|((d&8)>>1),0x8d,((d&7)<<3)|5,@@[4,*(a-$.,%%)]
LEA d,[b]       ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8d,((d&7)<<3)|(b&7)
LEA d,[b+!o]    ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8d,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
LEA d,[b+!o]B   ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x8d,0x40|((d&7)<<3)|(b&7),(o&0xff)

/* ====================== 条件分岐 (32bit 相対、各 6 バイト) ====================== */
JO   !a  ::  ::  0x0f,0x80,@@[4,*(a-$.,%%)]
JNO  !a  ::  ::  0x0f,0x81,@@[4,*(a-$.,%%)]
JB   !a  ::  ::  0x0f,0x82,@@[4,*(a-$.,%%)]
JC   !a  ::  ::  0x0f,0x82,@@[4,*(a-$.,%%)]
JNAE !a  ::  ::  0x0f,0x82,@@[4,*(a-$.,%%)]
JNB  !a  ::  ::  0x0f,0x83,@@[4,*(a-$.,%%)]
JNC  !a  ::  ::  0x0f,0x83,@@[4,*(a-$.,%%)]
JAE  !a  ::  ::  0x0f,0x83,@@[4,*(a-$.,%%)]
JE   !a  ::  ::  0x0f,0x84,@@[4,*(a-$.,%%)]
JZ   !a  ::  ::  0x0f,0x84,@@[4,*(a-$.,%%)]
JNE  !a  ::  ::  0x0f,0x85,@@[4,*(a-$.,%%)]
JNZ  !a  ::  ::  0x0f,0x85,@@[4,*(a-$.,%%)]
JBE  !a  ::  ::  0x0f,0x86,@@[4,*(a-$.,%%)]
JNA  !a  ::  ::  0x0f,0x86,@@[4,*(a-$.,%%)]
JA   !a  ::  ::  0x0f,0x87,@@[4,*(a-$.,%%)]
JNBE !a  ::  ::  0x0f,0x87,@@[4,*(a-$.,%%)]
JS   !a  ::  ::  0x0f,0x88,@@[4,*(a-$.,%%)]
JNS  !a  ::  ::  0x0f,0x89,@@[4,*(a-$.,%%)]
JP   !a  ::  ::  0x0f,0x8a,@@[4,*(a-$.,%%)]
JPE  !a  ::  ::  0x0f,0x8a,@@[4,*(a-$.,%%)]
JNP  !a  ::  ::  0x0f,0x8b,@@[4,*(a-$.,%%)]
JPO  !a  ::  ::  0x0f,0x8b,@@[4,*(a-$.,%%)]
JL   !a  ::  ::  0x0f,0x8c,@@[4,*(a-$.,%%)]
JNGE !a  ::  ::  0x0f,0x8c,@@[4,*(a-$.,%%)]
JGE  !a  ::  ::  0x0f,0x8d,@@[4,*(a-$.,%%)]
JNL  !a  ::  ::  0x0f,0x8d,@@[4,*(a-$.,%%)]
JLE  !a  ::  ::  0x0f,0x8e,@@[4,*(a-$.,%%)]
JNG  !a  ::  ::  0x0f,0x8e,@@[4,*(a-$.,%%)]
JG   !a  ::  ::  0x0f,0x8f,@@[4,*(a-$.,%%)]
JNLE !a  ::  ::  0x0f,0x8f,@@[4,*(a-$.,%%)]

/* 8-bit short branches */
JO8  !a  ::  ::  0x70,a-$.
JNO8 !a  ::  ::  0x71,a-$.
JB8  !a  ::  ::  0x72,a-$.
JNB8 !a  ::  ::  0x73,a-$.
JE8  !a  ::  ::  0x74,a-$.
JNE8 !a  ::  ::  0x75,a-$.
JBE8 !a  ::  ::  0x76,a-$.
JA8  !a  ::  ::  0x77,a-$.
JS8  !a  ::  ::  0x78,a-$.
JNS8 !a  ::  ::  0x79,a-$.
JP8  !a  ::  ::  0x7a,a-$.
JNP8 !a  ::  ::  0x7b,a-$.
JL8  !a  ::  ::  0x7c,a-$.
JGE8 !a  ::  ::  0x7d,a-$.
JLE8 !a  ::  ::  0x7e,a-$.
JG8  !a  ::  ::  0x7f,a-$.
JZ8  !a  ::  ::  0x74,a-$.
JNZ8 !a  ::  ::  0x75,a-$.
JC8  !a  ::  ::  0x72,a-$.
JNC8 !a  ::  ::  0x73,a-$.

/* ====================== 無条件分岐 ====================== */
JMP !a   ::  ::  0xe9,@@[4,*(a-$.,%%)]
JMP8 !a  ::  ::  0xeb,a-$.
JMP d    ::  ::  ;((d&8)?0x41:0),0xff,0xe0|(d&7)
JMP [b]  ::  ::  ;((b&8)?0x41:0),0xff,0x20|(b&7)

CALL !e  ::  ::  0xe8,@@[4,*(e-$.,%%)]
CALL d   ::  ::  ;((d&8)?0x41:0),0xff,0xd0|(d&7)
CALL [b] ::  ::  ;((b&8)?0x41:0),0xff,0x10|(b&7)

RET      ::  ::  0xc3
RET !i   ::  ::  0xc2,@@[2,*(i,%%)]
RETF     ::  ::  0xcb
RETF !i  ::  ::  0xca,@@[2,*(i,%%)]

/* ====================== SETCC (Set on Condition) ====================== */
SETO  d  ::  ::  ;((d&8)?0x41:0),0x0f,0x90,0xc0|(d&7)
SETNO d  ::  ::  ;((d&8)?0x41:0),0x0f,0x91,0xc0|(d&7)
SETB  d  ::  ::  ;((d&8)?0x41:0),0x0f,0x92,0xc0|(d&7)
SETNB d  ::  ::  ;((d&8)?0x41:0),0x0f,0x93,0xc0|(d&7)
SETE  d  ::  ::  ;((d&8)?0x41:0),0x0f,0x94,0xc0|(d&7)
SETNE d  ::  ::  ;((d&8)?0x41:0),0x0f,0x95,0xc0|(d&7)
SETBE d  ::  ::  ;((d&8)?0x41:0),0x0f,0x96,0xc0|(d&7)
SETA  d  ::  ::  ;((d&8)?0x41:0),0x0f,0x97,0xc0|(d&7)
SETS  d  ::  ::  ;((d&8)?0x41:0),0x0f,0x98,0xc0|(d&7)
SETNS d  ::  ::  ;((d&8)?0x41:0),0x0f,0x99,0xc0|(d&7)

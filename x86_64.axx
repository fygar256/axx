RDSEED d                 ::  ::  0x48|((d&8)>>3),0x0f,0xc7,0xf8|(d&7)
RDSEED DWORD d           ::  ::  ;((d&8)?0x41:0),0x0f,0xc7,0xf8|(d&7)

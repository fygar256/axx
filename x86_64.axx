/* ====================== CMOV (Conditional Move) ====================== */
CMOVO  d,s  ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0x40,0xc0|((d&7)<<3)|(s&7)
CMOVNO d,s  ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0x41,0xc0|((d&7)<<3)|(s&7)
